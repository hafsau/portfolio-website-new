---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbientBackground from '../components/AmbientBackground.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <AmbientBackground variant="subtle" />

  <!-- Floating Particles -->
  <div class="particles-container" aria-hidden="true">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
  </div>

  <main class="error-page">
    <div class="error-content">
      <!-- Glitch 404 -->
      <div class="error-code-wrapper">
        <div class="error-code" data-text="404">404</div>
      </div>

      <!-- Playful Copy -->
      <h1 class="error-title">Looks like you're lost.</h1>
      <p class="error-description">
        But hey, getting lost is how you discover new things.
      </p>

      <!-- Navigation -->
      <div class="error-actions">
        <a href="/" class="error-home-link magnetic-btn">
          <span class="btn-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
          </span>
          <span class="btn-text">Back to Home</span>
        </a>
        <a href="/#work" class="error-work-link">
          <span>See My Work</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  /* Particles Container */
  .particles-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 5;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 6px;
    height: 6px;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
    border-radius: 50%;
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
    filter: blur(0.5px);
  }

  .particle:nth-child(3n+1) {
    width: 4px;
    height: 4px;
  }

  .particle:nth-child(3n+2) {
    width: 8px;
    height: 8px;
  }

  /* Error Page Layout */
  .error-page {
    min-height: 100vh;
    max-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  :global(html),
  :global(body) {
    height: 100vh;
    max-height: 100vh;
    overflow: hidden !important;
  }

  :global(footer) {
    display: none;
  }

  .error-content {
    text-align: center;
    max-width: 500px;
  }

  /* Glitch Effect */
  .error-code-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .error-code {
    font-size: clamp(8rem, 25vw, 14rem);
    font-weight: 900;
    color: var(--color-fg);
    line-height: 1;
    position: relative;
    letter-spacing: -0.05em;
    animation: glitch-skew 4s infinite linear alternate-reverse;
  }

  .error-code::before,
  .error-code::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0.8;
  }

  .error-code::before {
    color: #ff00ff;
    animation: glitch-1 2s infinite linear alternate-reverse;
    clip-path: polygon(0 0, 100% 0, 100% 35%, 0 35%);
  }

  .error-code::after {
    color: #00ffff;
    animation: glitch-2 3s infinite linear alternate-reverse;
    clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
  }

  @keyframes glitch-1 {
    0%, 100% {
      transform: translate(0);
    }
    20% {
      transform: translate(-3px, 3px);
    }
    40% {
      transform: translate(-3px, -3px);
    }
    60% {
      transform: translate(3px, 3px);
    }
    80% {
      transform: translate(3px, -3px);
    }
  }

  @keyframes glitch-2 {
    0%, 100% {
      transform: translate(0);
    }
    20% {
      transform: translate(3px, -3px);
    }
    40% {
      transform: translate(3px, 3px);
    }
    60% {
      transform: translate(-3px, -3px);
    }
    80% {
      transform: translate(-3px, 3px);
    }
  }

  @keyframes glitch-skew {
    0%, 100% {
      transform: skew(0deg);
    }
    20% {
      transform: skew(-0.5deg);
    }
    40% {
      transform: skew(0.5deg);
    }
    60% {
      transform: skew(-0.3deg);
    }
    80% {
      transform: skew(0.3deg);
    }
  }

  /* Title & Description */
  .error-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    color: var(--color-fg);
    margin: 0 0 0.75rem;
  }

  .error-description {
    font-size: 1rem;
    color: var(--color-muted);
    margin: 0 0 2.5rem;
    line-height: 1.6;
  }

  /* Actions */
  .error-actions {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Primary Button */
  .error-home-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 3rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease, background 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .error-home-link:hover {
    box-shadow: 0 10px 40px rgba(74, 94, 228, 0.3);
  }

  .error-home-link .btn-icon {
    display: flex;
    align-items: center;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .error-home-link:hover .btn-icon {
    transform: translateX(-6px);
  }

  .error-home-link .btn-icon svg {
    display: block;
  }

  /* Secondary Link */
  .error-work-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 0.5rem;
  }

  .error-work-link:hover {
    color: var(--color-accent);
  }

  .error-work-link svg {
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .error-work-link:hover svg {
    transform: translateX(6px);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .error-code,
    .error-code::before,
    .error-code::after {
      animation: none;
    }

    .particle {
      animation: none;
      opacity: 0.3;
    }

    .error-home-link,
    .error-home-link .btn-icon,
    .error-work-link svg {
      transition: none;
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .error-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .error-home-link {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  function init404Page() {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;
    const isDesktop = window.innerWidth >= 768 && !isTouchDevice;

    const particles = document.querySelectorAll('.particle') as NodeListOf<HTMLElement>;
    const particleCount = particles.length;

    // Particle system - smooth cursor follow
    if (!prefersReducedMotion && isDesktop && particleCount > 0) {
      // Initialize positions at center
      const centerX = window.innerWidth / 2;
      const centerY = window.innerHeight / 2;

      const state = Array.from(particles).map((_, i) => ({
        x: centerX,
        y: centerY,
        angle: (i / particleCount) * Math.PI * 2,
        radius: 80 + (i % 4) * 30,
        speed: 0.015 + (i % 5) * 0.003,
        rotationSpeed: 0.0003 + (i % 3) * 0.0001
      }));

      // Fade in particles elegantly
      gsap.to(particles, {
        opacity: (i) => 0.3 + (i % 3) * 0.15,
        duration: 1.5,
        stagger: 0.08,
        ease: 'power2.out'
      });

      // Set initial positions
      particles.forEach((particle, i) => {
        gsap.set(particle, {
          x: state[i].x,
          y: state[i].y,
          xPercent: -50,
          yPercent: -50
        });
      });

      // Track mouse with smoothing
      let mouseX = centerX;
      let mouseY = centerY;
      let targetMouseX = centerX;
      let targetMouseY = centerY;

      document.addEventListener('mousemove', (e) => {
        targetMouseX = e.clientX;
        targetMouseY = e.clientY;
      });

      // Smooth animation loop
      const animate = () => {
        // Smooth mouse tracking
        mouseX += (targetMouseX - mouseX) * 0.08;
        mouseY += (targetMouseY - mouseY) * 0.08;

        particles.forEach((particle, i) => {
          const s = state[i];

          // Slowly rotate the orbit angle
          s.angle += s.rotationSpeed;

          // Calculate target position in orbit around cursor
          const targetX = mouseX + Math.cos(s.angle) * s.radius;
          const targetY = mouseY + Math.sin(s.angle) * s.radius;

          // Smooth interpolation
          s.x += (targetX - s.x) * s.speed;
          s.y += (targetY - s.y) * s.speed;

          // Apply transform
          gsap.set(particle, {
            x: s.x,
            y: s.y
          });
        });

        requestAnimationFrame(animate);
      };

      animate();
    }

    // Magnetic button effect
    if (!prefersReducedMotion && isDesktop) {
      const btn = document.querySelector('.magnetic-btn') as HTMLElement;
      if (btn) {
        btn.addEventListener('mousemove', (e) => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          gsap.to(btn, {
            x: x * 0.25,
            y: y * 0.25,
            duration: 0.4,
            ease: 'power3.out'
          });
        });

        btn.addEventListener('mouseleave', () => {
          gsap.to(btn, {
            x: 0,
            y: 0,
            duration: 0.7,
            ease: 'elastic.out(1, 0.4)'
          });
        });
      }
    }
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init404Page);
  } else {
    init404Page();
  }
</script>
