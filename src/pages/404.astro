---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbientBackground from '../components/AmbientBackground.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <AmbientBackground variant="subtle" />

  <main class="error-page">
    <div class="error-code" aria-hidden="true">404</div>
    <h1 class="error-title">Well, this is awkward.</h1>
    <p class="error-description">
      This page doesn't exist—but I promise the rest of my work does.
    </p>
    <div class="error-actions">
      <a href="/" class="error-home-link magnetic-btn">
        Back to Home
      </a>
      <a href="/#work" class="error-work-link">
        See My Work
      </a>
    </div>
  </main>

  <style>
    .error-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      flex-wrap: wrap;
      justify-content: center;
    }

    .error-work-link {
      color: var(--color-muted);
      font-size: 0.875rem;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .error-work-link:hover {
      color: var(--color-accent);
    }
  </style>

  <script>
    // Magnetic button effect
    const magneticBtn = document.querySelector('.magnetic-btn') as HTMLElement;

    if (magneticBtn && window.innerWidth > 768) {
      magneticBtn.addEventListener('mousemove', (e) => {
        const rect = magneticBtn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;

        magneticBtn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
      });

      magneticBtn.addEventListener('mouseleave', () => {
        magneticBtn.style.transform = 'translate(0, 0)';
      });
    }
  </script>
</BaseLayout>
