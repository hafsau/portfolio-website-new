---
import BaseLayout from '../layouts/BaseLayout.astro';

const experience = [
  {
    title: 'Product Design Program',
    company: 'CareerFoundry',
    period: '2024 - 2025',
    description: 'Intensive program covering end-to-end product design: user research, wireframing, prototyping, usability testing, and visual design.'
  },
  {
    title: 'Assistant Program Manager',
    company: 'IT Board, Government of Punjab',
    period: '2014 - 2015',
    description: 'Co-led development of child immunization monitoring app deployed across 36 cities. Increased vaccinator attendance from 21% to 91%.'
  },
  {
    title: 'Research Assistant',
    company: 'IT Board, Government of Punjab',
    period: '2013 - 2014',
    description: 'Prototyped water conservation system and conducted user research with 250+ participants, achieving 36% increase in satisfaction scores.'
  }
];

const education = [
  {
    degree: 'MS in Computer Science',
    school: 'Information Technology University, Lahore',
    period: '2013 - 2015',
    note: 'Magna Cum Laude, 3.6 GPA'
  },
  {
    degree: 'BS in Electrical Engineering',
    school: 'NUCES, Lahore',
    period: '2008 - 2012',
    note: 'Concentration in Telecommunication, 3.3 GPA'
  }
];

const skills = {
  design: ['Figma', 'FigJam', 'Miro', 'Wireframing', 'Prototyping', 'User Research', 'Usability Testing', 'Visual Design'],
  technical: ['HTML/CSS', 'JavaScript', 'Python', 'AWS', 'GCP', 'API Integration', 'Git'],
  methods: ['User Interviews', 'Competitive Analysis', 'Persona Development', 'Journey Mapping', 'A/B Testing'],
  ai: ['Claude', 'ChatGPT', 'Replit Agent', 'v0 by Vercel', 'Midjourney', 'Prompt Engineering']
};

// Skills with proficiency levels for visual display
const skillsWithProficiency = [
  { category: 'Design', skills: [
    { name: 'Figma', level: 95 },
    { name: 'User Research', level: 90 },
    { name: 'Prototyping', level: 90 },
    { name: 'Wireframing', level: 95 },
    { name: 'Visual Design', level: 85 },
    { name: 'Usability Testing', level: 85 },
  ]},
  { category: 'Technical', skills: [
    { name: 'HTML/CSS', level: 90 },
    { name: 'JavaScript', level: 75 },
    { name: 'Python', level: 70 },
    { name: 'Git', level: 80 },
    { name: 'AWS/GCP', level: 65 },
  ]},
  { category: 'AI Tools', skills: [
    { name: 'Claude', level: 95 },
    { name: 'Prompt Engineering', level: 90 },
    { name: 'ChatGPT', level: 85 },
    { name: 'Cursor/v0', level: 80 },
    { name: 'Midjourney', level: 75 },
  ]},
];

// Currently section data
const currently = {
  working: 'Building AI-powered tools and refining my portfolio',
  learning: 'Advanced GSAP animations and Three.js',
  reading: 'Refactoring UI by Adam Wathan',
  listening: 'Lenny\'s Podcast and Design Better',
};
---

<BaseLayout title="About" currentPath="/about">
  <section class="max-w-[680px] mx-auto px-6 py-16">
    <!-- Header -->
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 reveal">About</h1>
    </div>

    <!-- Photo placeholder + Bio -->
    <div class="mb-16">
      <div class="about-photo reveal">
        <img src="/images/headshot.png" alt="Hafsa Usmani, Product Designer" />
      </div>

      <div class="space-y-4 text-lg text-[var(--color-muted)] reveal reveal-2">
        <p>
          I'm a <strong class="text-[var(--color-foreground)]">Product Designer who speaks both design and engineering</strong>.
          With an MS in Computer Science and hands-on development experience, I bring a unique perspective
          to design challenges.
        </p>
        <p>
          Before transitioning to design, I led a cross-functional team that built a healthcare app
          increasing vaccination coverage across 36 cities in Pakistan. I've launched products that
          scaled to 190 countries and won awards in Google's developer contests.
        </p>
        <p>
          I recently completed CareerFoundry's Product Design program to formalize my UX expertise,
          combining it with my technical foundation to design solutions that are both
          <strong class="text-[var(--color-foreground)]">user-centered and technically sound</strong>.
        </p>
        <p>
          Currently based in the San Francisco Bay Area, I'm looking for Product Designer roles
          where I can apply this unique blend of design thinking and engineering understanding.
        </p>
      </div>
    </div>

    <!-- Experience -->
    <div class="mb-16">
      <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-6 reveal">Experience</h2>
      <div class="space-y-8">
        {experience.map((job, index) => (
          <div class={`reveal reveal-${index + 1}`}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-2">
              <div>
                <h3 class="font-semibold">{job.title}</h3>
                <p class="text-[var(--color-muted)]">{job.company}</p>
              </div>
              <p class="text-sm text-[var(--color-muted)] md:text-right">{job.period}</p>
            </div>
            <p class="text-[var(--color-muted)] text-sm">{job.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Education -->
    <div class="mb-16">
      <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-6 reveal">Education</h2>
      <div class="space-y-6">
        {education.map((edu, index) => (
          <div class={`reveal reveal-${index + 1}`}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-1">
              <div>
                <h3 class="font-semibold">{edu.degree}</h3>
                <p class="text-[var(--color-muted)]">{edu.school}</p>
              </div>
              <p class="text-sm text-[var(--color-muted)] md:text-right">{edu.period}</p>
            </div>
            <p class="text-sm text-[var(--color-muted)]">{edu.note}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills with Proficiency Bars -->
    <div class="mb-16">
      <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-6 reveal">Skills</h2>
      <div class="skills-grid">
        {skillsWithProficiency.map((category, catIndex) => (
          <div class={`skill-category reveal reveal-${catIndex + 1}`}>
            <h3 class="font-semibold mb-4 text-[var(--color-accent)]">{category.category}</h3>
            <div class="skill-list">
              {category.skills.map((skill) => (
                <div class="skill-item">
                  <div class="skill-header">
                    <span class="skill-name">{skill.name}</span>
                    <span class="skill-percent">{skill.level}%</span>
                  </div>
                  <div class="skill-bar">
                    <div class="skill-fill" style={`--skill-level: ${skill.level}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Currently Section -->
    <div class="mb-16">
      <h2 class="text-sm uppercase tracking-wider text-[var(--color-muted)] mb-6 reveal">Currently</h2>
      <div class="currently-grid reveal reveal-1">
        <div class="currently-item">
          <span class="currently-label">Working on</span>
          <p class="currently-value">{currently.working}</p>
        </div>
        <div class="currently-item">
          <span class="currently-label">Learning</span>
          <p class="currently-value">{currently.learning}</p>
        </div>
        <div class="currently-item">
          <span class="currently-label">Reading</span>
          <p class="currently-value">{currently.reading}</p>
        </div>
        <div class="currently-item">
          <span class="currently-label">Listening to</span>
          <p class="currently-value">{currently.listening}</p>
        </div>
      </div>
    </div>

    <!-- Download Resume -->
    <div class="reveal">
      <a
        href="/Hafsa Usmani - Resume.pdf"
        target="_blank"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-accent)] text-white rounded-lg font-medium hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Download Resume
      </a>
    </div>
  </section>

  <style>
    /* Skills Grid with Proficiency Bars */
    .skills-grid {
      display: grid;
      gap: 2rem;
    }

    @media (min-width: 640px) {
      .skills-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
      }
    }

    .skill-category {
      padding: 1.5rem;
      background: var(--color-card);
      border: 1px solid var(--color-border);
      border-radius: 12px;
    }

    .skill-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .skill-item {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .skill-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .skill-name {
      font-size: 0.875rem;
      color: var(--color-foreground);
    }

    .skill-percent {
      font-size: 0.75rem;
      color: var(--color-muted);
      font-weight: 500;
    }

    .skill-bar {
      height: 6px;
      background: var(--color-border);
      border-radius: 100px;
      overflow: hidden;
    }

    .skill-fill {
      height: 100%;
      width: var(--skill-level);
      background: linear-gradient(90deg, var(--color-accent), #667eea);
      border-radius: 100px;
      transition: width 1s ease-out;
    }

    /* Currently Section */
    .currently-grid {
      display: grid;
      gap: 1.25rem;
    }

    @media (min-width: 640px) {
      .currently-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
    }

    .currently-item {
      padding: 1.25rem;
      background: var(--color-card);
      border: 1px solid var(--color-border);
      border-radius: 12px;
      transition: border-color 0.2s ease;
    }

    .currently-item:hover {
      border-color: var(--color-accent);
    }

    .currently-label {
      display: block;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-accent);
      margin-bottom: 0.5rem;
      font-weight: 600;
    }

    .currently-value {
      font-size: 0.95rem;
      color: var(--color-foreground);
      line-height: 1.5;
      margin: 0;
    }

    /* About photo styling */
    .about-photo {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      overflow: hidden;
      margin-bottom: 2rem;
      border: 3px solid var(--color-border);
    }

    .about-photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  </style>
</BaseLayout>
