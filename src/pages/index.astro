  <!-- Scripts -->
  <script>
    // Ensure dark mode (clear any previous light mode setting)
    document.documentElement.classList.remove('light');
    localStorage.removeItem('theme');

    // Section-wide drag cursor that follows mouse - created dynamically
    function initSectionDragCursor() {
      const workSection = document.getElementById('work');
      if (!workSection) return;
      if (workSection.dataset.cursorInit === 'true') return;
      workSection.dataset.cursorInit = 'true';

      // Create drag cursor element dynamically - matching site's cursor style
      let dragCursor = document.getElementById('drag-cursor-element');
      if (!dragCursor) {
        dragCursor = document.createElement('div');
        dragCursor.id = 'drag-cursor-element';
        dragCursor.textContent = 'Drag';
        dragCursor.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          pointer-events: none;
          z-index: 99999;
          display: flex;
          align-items: center;
          justify-content: center;
          width: 80px;
          height: 80px;
          background: #4a5ee4;
          color: #fff;
          border-radius: 50%;
          font-size: 13px;
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 1px;
          font-family: 'Space Grotesk', sans-serif;
          opacity: 0;
          transform: translate(-50%, -50%);
          transition: opacity 0.2s ease, transform 0.2s ease;
          box-shadow: 0 4px 20px rgba(74, 94, 228, 0.4);
        `;
        document.body.appendChild(dragCursor);
      }

      let isInSection = false;
      let mouseX = 0;
      let mouseY = 0;
      let cursorX = 0;
      let cursorY = 0;
      let rafId: number;

      function updateCursor() {
        cursorX += (mouseX - cursorX) * 0.15;
        cursorY += (mouseY - cursorY) * 0.15;

        dragCursor!.style.left = `${cursorX}px`;
        dragCursor!.style.top = `${cursorY}px`;

        if (isInSection) {
          rafId = requestAnimationFrame(updateCursor);
        }
      }

      workSection.addEventListener('mouseenter', (e: MouseEvent) => {
        isInSection = true;
        mouseX = e.clientX;
        mouseY = e.clientY;
        cursorX = mouseX;
        cursorY = mouseY;
        dragCursor!.style.left = `${cursorX}px`;
        dragCursor!.style.top = `${cursorY}px`;
        dragCursor!.style.opacity = '1';
        rafId = requestAnimationFrame(updateCursor);
      });

      workSection.addEventListener('mousemove', (e: MouseEvent) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
      });

      workSection.addEventListener('mouseleave', () => {
        isInSection = false;
        dragCursor!.style.opacity = '0';
        cancelAnimationFrame(rafId);
      });

      // Hide drag cursor when hovering over Discover buttons
      const ctaButtons = workSection.querySelectorAll('.project-cta');
      ctaButtons.forEach((btn) => {
        btn.addEventListener('mouseenter', () => {
          dragCursor!.style.opacity = '0';
        });
        btn.addEventListener('mouseleave', () => {
          if (isInSection) {
            dragCursor!.style.opacity = '1';
          }
        });
      });
    }

    // Initialize on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSectionDragCursor);
    } else {
      initSectionDragCursor();
    }
    document.addEventListener('astro:after-swap', initSectionDragCursor);

    // Infinite Loop Draggable Carousel with 3D Effect
    function initDraggableCarousel() {
      const carousel = document.getElementById('projects-carousel');
      const track = document.getElementById('projects-track');
      if (!carousel || !track) return;

      // Check if already initialized
      if (carousel.dataset.init === 'true') return;
      carousel.dataset.init = 'true';

      const cardWrappers = track.querySelectorAll('.project-card-wrapper') as NodeListOf<HTMLElement>;
      const totalCards = cardWrappers.length;
      const originalCards = totalCards / 2; // We have duplicates

      let isDragging = false;
      let startX = 0;
      let scrollLeft = 0;
      let currentX = 0;
      let velocityX = 0;
      let lastX = 0;
      let lastTime = 0;
      let animationId: number;

      const friction = 0.94;
      const minVelocity = 0.3;

