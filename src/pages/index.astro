---
/**
 * Portfolio - Mind-Blowing Visual Design
 * Full-width name behind portrait, warm+dark contrast, wave dividers
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Magnet from '../components/Magnet.astro';
import BlurFadeIn from '../components/BlurFadeIn.astro';
import SplitTextReveal from '../components/SplitTextReveal.astro';
import MultilingualGreeting from '../components/MultilingualGreeting.astro';
import FloatingOrbs from '../components/FloatingOrbs.astro';
import ScrollFloatingElements from '../components/ScrollFloatingElements.astro';
import WaveDivider from '../components/WaveDivider.astro';
import TiltCard from '../components/TiltCard.astro';
import ScrollRevealText from '../components/ScrollRevealText.astro';
import CircleButton from '../components/CircleButton.astro';
import Marquee from '../components/Marquee.astro';
import StaggeredShapes from '../components/StaggeredShapes.astro';
import HamburgerMenu from '../components/HamburgerMenu.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

// Navigation items for hamburger menu
const navItems = [
  { label: 'Work', href: '#work' },
  { label: 'About', href: '#about' },
  { label: 'Contact', href: '#contact' },
];

// Project data
const projects = [
  {
    number: '01',
    category: 'EdTech',
    title: 'EqualTales',
    description: 'AI-powered children\'s storybook',
    image: '/images/equaltales/hero.png',
    href: '/work/equaltales',
    color: '#7B5EA7',
    year: '2026'
  },
  {
    number: '02',
    category: 'Portfolio',
    title: 'HafsaUsmani.com',
    description: 'AI-assisted portfolio development',
    image: '/images/portfolio-website/after-typography.png',
    href: '/work/portfolio-website',
    color: '#14b8a6',
    year: '2026'
  },
  {
    number: '03',
    category: 'AI Lab',
    title: 'Creative Experiments',
    description: 'AI-powered design tools and experiments',
    image: '/images/ai-lab/hero-image.svg',
    href: '/work/ai-lab',
    color: '#f97316',
    year: '2026'
  },
  {
    number: '04',
    category: 'Healthcare',
    title: 'MedRec Platform',
    description: 'Digital health records for millions',
    image: '/images/medrec/hero-medrec.png',
    href: '/work/medrec',
    color: '#4a5ee4',
    year: '2025'
  },
  {
    number: '05',
    category: 'Wellness',
    title: 'FitStart App',
    description: 'Fitness journey companion',
    image: '/images/fitstart/hero-image.png',
    href: '/work/fitstart',
    color: '#8b5cf6',
    year: '2025'
  },
  {
    number: '06',
    category: 'Finance',
    title: 'Folio Platform',
    description: 'Investment portfolio tracking',
    image: '/images/folio/hero-image.png',
    href: '/work/folio',
    color: '#0891b2',
    year: '2025'
  },
  {
    number: '07',
    category: 'Government',
    title: 'Immunization Tracker',
    description: 'Healthcare monitoring at scale',
    image: '/images/immunization/hero-image.png',
    href: '/work/immunization',
    color: '#4a5ee4',
    year: '2015'
  }
];

// Stats data
const stats = [
  { number: '30', suffix: '%', label: 'User Efficiency' },
  { number: '5', suffix: '+', label: 'Years Experience' },
  { number: '10', suffix: 'M+', label: 'Users Reached' }
];

// Skills for marquee
const skills = [
  { name: 'Figma', icon: 'M12 2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2h-4zm0 2h4v4h-4V4zm-6 6a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H6zm2 2h2v2H8v-2z' },
  { name: 'Design Systems', icon: 'M3 3h8v8H3V3zm2 2v4h4V5H5zm8-2h8v8h-8V3zm2 2v4h4V5h-4zM3 13h8v8H3v-8zm2 2v4h4v-4H5zm8-2h8v8h-8v-8zm2 2v4h4v-4h-4z' },
  { name: 'Wireframing', icon: 'M3 3h18v18H3V3zm2 2v14h14V5H5zm2 2h10v3H7V7zm0 5h4v5H7v-5zm6 0h4v2h-4v-2zm0 3h4v2h-4v-2z' },
  { name: 'Accessibility', icon: 'M12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 7h-6v13h-2v-6h-2v6H9V9H3V7h18v2z' },
  { name: 'Responsive Design', icon: 'M4 6h18V4H4c-1.1 0-2 .9-2 2v11H0v3h14v-3H4V6zm19 2h-6c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h6c.55 0 1-.45 1-1V9c0-.55-.45-1-1-1zm-1 9h-4v-7h4v7z' },
  { name: 'User Research', icon: 'M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z' },
  { name: 'Prototyping', icon: 'M17 3H7c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H7V5h10v14zM8 7h8v2H8zm0 4h8v2H8zm0 4h5v2H8z' },
  { name: 'Usability Testing', icon: 'M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14l-5-5 1.41-1.41L12 14.17l4.59-4.58L18 11l-6 6z' },
  { name: 'Visual Design', icon: 'M12 22C6.49 22 2 17.51 2 12S6.49 2 12 2s10 4.04 10 9c0 3.31-2.69 6-6 6h-1.77c-.28 0-.5.22-.5.5 0 .12.05.23.13.33.41.47.64 1.06.64 1.67A2.5 2.5 0 0 1 12 22zm0-18c-4.41 0-8 3.59-8 8s3.59 8 8 8c.28 0 .5-.22.5-.5a.54.54 0 0 0-.14-.35c-.41-.46-.63-1.05-.63-1.65a2.5 2.5 0 0 1 2.5-2.5H16c2.21 0 4-1.79 4-4 0-3.86-3.59-7-8-7z' },
  { name: 'React', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z' },
  { name: 'TypeScript', icon: 'M3 3h18v18H3V3zm16.5 8.5v-2h-6v2h2v6h2v-6h2zm-10.5 6h2v-4h2v-2h-6v2h2v4z' },
  { name: 'HTML/CSS', icon: 'M4 3l1.5 17L12 22l6.5-2L20 3H4zm13.5 5H8l.25 2.5h9l-.75 8.5L12 20l-4.5-1-0.25-3h2l0.15 1.5 2.6.7 2.6-.7.25-3H7.5L7 8h10l-.5 0z' },
  { name: 'Python', icon: 'M12 2C9.5 2 8 3.5 8 5v1H6c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h1v4c0 1.5 1.5 3 4 3h2c2.5 0 4-1.5 4-3v-1h2c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-1V5c0-1.5-1.5-3-4-3h-2zm0 2h2c1 0 2 .5 2 1v1h-6V5c0-.5 1-1 2-1z' },
  { name: 'Claude AI', icon: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z' },
  { name: 'AWS', icon: 'M6.5 9.5L3 12l3.5 2.5v-2H12v-1H6.5v-2zm11 0v2H12v1h5.5v2L21 12l-3.5-2.5z' },
];
---

<BaseLayout title="Home" ogImage="/images/headshot.png" useBarba={false} showLoadingScreen={true}>
  <!-- Hamburger Menu - in fixed slot outside Barba -->
  <HamburgerMenu slot="fixed" items={navItems} />

  <!-- Scroll Progress Indicator -->
  <ScrollProgress />

  <!-- Scroll-linked Floating Elements (parallax orbs) -->
  <ScrollFloatingElements />

  <div class="portfolio-wrapper">

    <!-- ============================================
         HERO SECTION - Warm Cream Background
         ============================================ -->
    <section class="hero-section">
      <FloatingOrbs />

      <!-- Navigation -->
      <BlurFadeIn delay={0.3} y={-20} class="hero-nav">
        <nav class="hero-nav-inner">
          <a href="#work" class="nav-link" data-cursor-text="Go">Work</a>
          <a href="#about" class="nav-link" data-cursor-text="Go">About</a>
          <a href="#contact" class="nav-link" data-cursor-text="Go">Contact</a>
        </nav>
      </BlurFadeIn>

      <!-- Multilingual Greeting -->
      <div class="greeting-wrapper">
        <BlurFadeIn delay={0} y={20}>
          <MultilingualGreeting
            greetings={['Hello', 'Bonjour', 'Hola', 'नमस्ते', 'Ciao', '你好', 'こんにちは', '안녕하세요', 'السلام علیکم', 'Olá']}
            interval={2000}
            class="hero-greeting"
          />
        </BlurFadeIn>
      </div>

      <!-- Main Hero Content: Name + Portrait -->
      <div class="hero-content">
        <!-- First Name -->
        <div class="hero-name-row">
          <h1 class="hero-name hero-name-first">
            <SplitTextReveal
              text="HAFSA"
              tag="span"
              stagger={30}
              duration={0.7}
              delay={500}
            />
          </h1>
        </div>

        <!-- Portrait (overlaid) - with parallax -->
        <div class="hero-portrait-container" data-parallax data-speed="0.15">
          <BlurFadeIn delay={0.7} y={40} duration={1}>
            <Magnet padding={150} strength={0.4}>
              <div class="hero-portrait-wrapper">
                <img
                  src="/images/headshot.png"
                  alt="Hafsa Usmani"
                  class="hero-portrait"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                  sizes="(max-width: 640px) 200px, (max-width: 768px) 280px, (max-width: 1024px) 360px, 420px"
                />
              </div>
            </Magnet>
          </BlurFadeIn>
        </div>

        <!-- Last Name -->
        <div class="hero-name-row">
          <h1 class="hero-name hero-name-last">
            <SplitTextReveal
              text="USMANI"
              tag="span"
              stagger={30}
              duration={0.7}
              delay={900}
            />
          </h1>
        </div>
      </div>

      <!-- Subtitle + CTA -->
      <div class="hero-footer">
        <BlurFadeIn delay={1.2} y={20}>
          <p class="hero-subtitle">Product Designer · San Francisco Bay Area</p>
        </BlurFadeIn>
        <BlurFadeIn delay={1.4} y={20}>
          <Magnet padding={300} strength={0.5}>
            <a href="#work" class="hero-cta" data-cursor-text="Go">
              See my work
              <svg class="arrow-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M7 17L17 7M17 7H7M17 7V17"/>
              </svg>
            </a>
          </Magnet>
        </BlurFadeIn>
      </div>
    </section>

    <!-- Wave Transition: Cream → Dark -->
    <WaveDivider class="wave-to-dark" />

    <!-- ============================================
         WORK SECTION - Dark Background
         ============================================ -->
    <section class="work-section" id="work">
      <div class="work-header">
        <BlurFadeIn delay={0} y={40} triggerOnScroll>
          <h2 class="section-title section-title-light">Selected Work</h2>
        </BlurFadeIn>
      </div>

      <!-- Draggable Projects Carousel -->
      <div class="projects-carousel" id="projects-carousel">
        <!-- Drag Indicator with dots -->
        <div class="drag-indicator" id="drag-indicator">
          <span class="drag-dots drag-dots-left">
            <span class="drag-dot"></span>
            <span class="drag-dot"></span>
            <span class="drag-dot"></span>
          </span>
          <span class="drag-text">Drag</span>
          <span class="drag-dots drag-dots-right">
            <span class="drag-dot"></span>
            <span class="drag-dot"></span>
            <span class="drag-dot"></span>
          </span>
        </div>

        <div class="projects-scroll-track" id="projects-track">
          {/* First set of cards */}
          {projects.map((project, i) => (
            <div class="project-card-wrapper" style={`--accent: ${project.color};`}>
              <div class="project-card">
                <div class="project-card-image">
                  <img src={project.image} alt={project.title} loading="lazy" decoding="async" />
                  <span class="project-year">{project.year}</span>
                </div>
                <div class="project-card-content">
                  <span class="project-number">{project.number}</span>
                  <span class="project-category">{project.category}</span>
                  <h3 class="project-title">{project.title}</h3>
                  <p class="project-description">{project.description}</p>
                  <a href={project.href} class="project-cta" data-cursor-text="View">Discover</a>
                </div>
              </div>
            </div>
          ))}
          {/* Duplicate set for infinite loop */}
          {projects.map((project, i) => (
            <div class="project-card-wrapper project-card-clone" style={`--accent: ${project.color};`}>
              <div class="project-card">
                <div class="project-card-image">
                  <img src={project.image} alt={project.title} loading="lazy" decoding="async" />
                  <span class="project-year">{project.year}</span>
                </div>
                <div class="project-card-content">
                  <span class="project-number">{project.number}</span>
                  <span class="project-category">{project.category}</span>
                  <h3 class="project-title">{project.title}</h3>
                  <p class="project-description">{project.description}</p>
                  <a href={project.href} class="project-cta" data-cursor-text="View">Discover</a>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Wave Transition: Dark → Cream -->
    <WaveDivider class="wave-to-warm" />

    <!-- ============================================
         STATS SECTION - Warm Cream Background
         ============================================ -->
    <section class="stats-section">
      <div class="stats-grid">
        {stats.map((stat, i) => (
          <BlurFadeIn delay={i * 0.15} y={40} triggerOnScroll>
            <div class="stat-item">
              <span class="stat-number" data-count={stat.number} data-suffix={stat.suffix}>
                0{stat.suffix}
              </span>
              <span class="stat-label">{stat.label}</span>
            </div>
          </BlurFadeIn>
        ))}
      </div>
    </section>

    <!-- Wave Transition: Cream → Dark -->
    <WaveDivider class="wave-to-dark" />

    <!-- ============================================
         ABOUT SECTION - Dark Background
         ============================================ -->
    <section class="about-section" id="about">
      <div class="about-content">
        <BlurFadeIn delay={0} y={40} triggerOnScroll>
          <h2 class="section-title section-title-light">About Me</h2>
        </BlurFadeIn>

        <BlurFadeIn delay={0.2} y={30} triggerOnScroll>
          <p class="rotating-intro">
            I'm a <span class="rotating-words">
              <span class="rotating-word">designer</span>
              <span class="rotating-word">maker</span>
              <span class="rotating-word">builder</span>
            </span>
          </p>
        </BlurFadeIn>

        <ScrollRevealText tag="p" class="about-text" stagger={0.015} threshold={0.2}>
          The combination of my passion for design, code & interaction positions me
          in a unique place in the design world.
        </ScrollRevealText>

        <ScrollRevealText tag="p" class="about-text" stagger={0.015} threshold={0.2}>
          With an MS in Computer Science and products shipped to millions of users,
          I bridge the gap between what's envisioned and what's engineered. I lead
          cross-functional teams to deliver experiences that move real metrics.
        </ScrollRevealText>

        <BlurFadeIn delay={0.4} y={20} triggerOnScroll>
          <div class="about-cta">
            <Magnet padding={60} strength={0.35}>
              <CircleButton href="#contact" variant="light" cursorText="Chat">
                Let's talk
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M7 17L17 7M17 7H7M17 7V17"/>
                </svg>
              </CircleButton>
            </Magnet>
          </div>
        </BlurFadeIn>
      </div>

      <!-- Skills Marquee - outside about-content for full width -->
      <div class="marquee-wrapper marquee-wrapper-dark">
        <Marquee duration={25}>
          {skills.map((skill) => (
            <span class="marquee-skill marquee-skill-dark">
              <svg viewBox="0 0 24 24" fill="currentColor" class="marquee-skill-icon">
                <path d={skill.icon} />
              </svg>
              <span class="marquee-skill-name">{skill.name}</span>
            </span>
          ))}
        </Marquee>
      </div>
    </section>

    <!-- Wave Transition: Dark → Cream -->
    <WaveDivider class="wave-to-warm" />

    <!-- ============================================
         CONTACT SECTION - Warm Cream Background
         ============================================ -->
    <section class="contact-section" id="contact">
      <div class="contact-content">
        <!-- Decorative staggered shapes -->
        <div class="contact-decorations">
          <StaggeredShapes variant="dots" count={4} color="rgba(12, 12, 12, 0.2)" />
        </div>

        <BlurFadeIn delay={0} y={40} triggerOnScroll>
          <h2 class="section-title">Let's Create<br/>Something Amazing</h2>
        </BlurFadeIn>

        <BlurFadeIn delay={0.2} y={30} triggerOnScroll>
          <div class="contact-links">
            <a href="mailto:hafsa.usmani2@gmail.com" class="contact-link" data-cursor-text="Email">
              hafsa.usmani2@gmail.com
            </a>
            <a href="https://www.linkedin.com/in/hafsausmani/" target="_blank" rel="noopener noreferrer" class="contact-link" data-cursor-text="Open">
              LinkedIn
            </a>
            <a href="https://github.com/hafsau" target="_blank" rel="noopener noreferrer" class="contact-link" data-cursor-text="Open">
              GitHub
            </a>
          </div>
        </BlurFadeIn>
      </div>

    </section>

    <!-- Footer with Copyright -->
    <footer class="footer">
      <p class="copyright">© 2026 Hafsa Usmani · San Francisco Bay Area</p>
    </footer>

  </div>


  <style>
    /* ============================================
       CSS VARIABLES
       ============================================ */
    :root {
      --warm-bg: #FFF4E4;
      --warm-fg: #1A1A1A;
      --warm-muted: #8B8680;
      --dark-bg: #0C0C0C;
      --dark-fg: #F5F5F0;
      --dark-muted: #B8B8B8;
      --accent: #4A5EE4;
      --card-bg: #1A1A1A;
      --card-border: #333;
      --card-image-bg: #0c0c0c;
    }

    /* Wave divider colors */
    .wave-to-dark {
      color: var(--dark-bg);
    }
    .wave-to-warm {
      color: var(--warm-bg);
    }

    /* ============================================
       GLOBAL WRAPPER
       ============================================ */
    .portfolio-wrapper {
      overflow-x: clip;
      font-family: 'Space Grotesk', sans-serif;
    }

    /* Prevent page transition overlay from causing extra space */
    #page-transition-overlay:not(.active) {
      display: none !important;
      visibility: hidden !important;
    }

    /* ============================================
       HERO SECTION - WARM CREAM
       ============================================ */
    .hero-section {
      min-height: 100vh;
      background: var(--warm-bg);
      color: var(--warm-fg);
      display: flex;
      flex-direction: column;
      position: relative;
      padding: 1.5rem;
      overflow: hidden;
    }

    @media (min-width: 768px) {
      .hero-section {
        padding: 2rem 3rem;
      }
    }

    /* Navigation */
    .hero-nav {
      position: relative;
      z-index: 10;
    }

    .hero-nav-inner {
      display: flex;
      justify-content: center;
      gap: 2rem;
    }

    @media (min-width: 768px) {
      .hero-nav-inner {
        gap: 4rem;
      }
    }

    .nav-link {
      color: var(--warm-fg);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-size: 0.75rem;
      text-decoration: none;
      position: relative;
      transition: opacity 0.2s ease;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 100%;
      height: 1px;
      background: var(--warm-fg);
      transform: scaleX(0);
      transform-origin: right center;
      transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    .nav-link:hover::after {
      transform: scaleX(1);
      transform-origin: left center;
    }

    @media (min-width: 768px) {
      .nav-link {
        font-size: 0.875rem;
      }
    }

    /* Greeting */
    .greeting-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
      margin-top: 1rem;
      position: relative;
      z-index: 10;
      padding-right: 1rem;
    }

    @media (min-width: 768px) {
      .greeting-wrapper {
        margin-top: 1.5rem;
        padding-right: 1.5rem;
      }
    }

    .hero-greeting {
      font-size: 0.875rem;
      color: var(--warm-muted);
      display: flex;
      justify-content: center;
      width: 100%;
    }

    @media (min-width: 768px) {
      .hero-greeting {
        font-size: 1rem;
      }
    }

    /* Hero Content: Name + Portrait */
    .hero-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      position: relative;
      z-index: 5;
      margin: 2rem 0;
    }

    .hero-name-row {
      width: 100%;
      display: flex;
      justify-content: center;
      overflow: visible;
    }

    .hero-name {
      font-family: var(--font-display);
      font-size: 18vw;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 0.85;
      color: var(--warm-fg);
      margin: 0;
      white-space: nowrap;
    }

    @media (min-width: 768px) {
      .hero-name {
        font-size: 20vw;
      }
    }

    @media (min-width: 1024px) {
      .hero-name {
        font-size: 22vw;
      }
    }

    /* Portrait Container */
    .hero-portrait-container {
      position: relative;
      z-index: 10;
      margin: -3vw 0;
    }

    @media (min-width: 768px) {
      .hero-portrait-container {
        margin: -5vw 0;
      }
    }

    .hero-portrait-wrapper {
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.15);
    }

    .hero-portrait {
      width: 200px;
      height: auto;
      display: block;
    }

    @media (min-width: 640px) {
      .hero-portrait {
        width: 280px;
      }
    }

    @media (min-width: 768px) {
      .hero-portrait {
        width: 360px;
