        const gap = parseFloat(getComputedStyle(track).gap) || 32;
        width += gap * originalCards;
        return width;
      }

      // Get initial offset to center first card (so cards appear on both sides)
      function getInitialOffset() {
        if (cardWrappers.length === 0) return 0;
        const firstCard = cardWrappers[0];
        const cardWidth = firstCard.offsetWidth;
        const gap = parseFloat(getComputedStyle(track).gap) || 32;
        // Start with 2 cards worth of offset so we see cards on the left
        return (cardWidth + gap) * 2;
