      // Apply curved arc path - cards follow parabolic curve, no rotation
      function update3DEffect() {
        const carouselRect = carousel.getBoundingClientRect();
        const centerX = carouselRect.left + carouselRect.width / 2;

        cardWrappers.forEach((wrapper) => {
          const wrapperRect = wrapper.getBoundingClientRect();
          const wrapperCenterX = wrapperRect.left + wrapperRect.width / 2;

          // Distance from center normalized (0 at center, 1+ at edges)
          const distanceFromCenter = wrapperCenterX - centerX;
          const cardWidth = wrapperRect.width;
          const normalizedDistance = Math.abs(distanceFromCenter) / cardWidth;

          // Parabolic Y offset - center card at top, side cards dip down
          // Using squared distance for smooth parabola shape
          const yOffset = Math.pow(normalizedDistance, 1.5) * maxYOffset;

          // Scale: center = 1, edges slightly smaller
          const scale = 1 - Math.min(normalizedDistance * 0.06, 0.12);

          // Z-index: center cards on top
          const zIndex = Math.round(10 - normalizedDistance * 2);

          // Apply arc transform - no rotation, just Y position and scale
          wrapper.style.transform = `translateY(${yOffset}px) scale(${scale})`;
          wrapper.style.zIndex = String(Math.max(zIndex, 1));
        });
      }

      // Set initial position to show cards on both sides
      currentX = getInitialOffset();

      // Handle infinite loop - wrap position when needed
      function wrapPosition() {
        const oneSetWidth = getOneSetWidth();

        // If scrolled past the first set, jump back
        if (currentX >= oneSetWidth) {
          currentX -= oneSetWidth;
        }
        // If scrolled before start, jump forward
        if (currentX < 0) {
          currentX += oneSetWidth;
        }
      }

      function updatePosition() {
        wrapPosition();
        track.style.transform = `translateX(${-currentX}px)`;
        update3DEffect();
      }

      function momentumScroll() {
        if (Math.abs(velocityX) > minVelocity) {
          currentX += velocityX;
          velocityX *= friction;
          updatePosition();
          animationId = requestAnimationFrame(momentumScroll);
        }
      }

      function onPointerDown(e: PointerEvent) {
        if (e.button !== 0) return;
        // Don't start dragging if clicking on a CTA button
        const target = e.target as HTMLElement;
        if (target.closest('.project-cta')) return;

        isDragging = true;
        carousel.classList.add('is-dragging');
        startX = e.clientX;
        lastX = e.clientX;
        lastTime = Date.now();
        scrollLeft = currentX;
        cancelAnimationFrame(animationId);
        carousel.setPointerCapture(e.pointerId);
        e.preventDefault();
      }

      function onPointerMove(e: PointerEvent) {
        if (!isDragging) return;
        e.preventDefault();

        const x = e.clientX;
        const now = Date.now();
        const dt = now - lastTime;

        if (dt > 0) {
          velocityX = (lastX - x) * (16 / dt);
        }

        const walk = startX - x;
        lastX = x;
        lastTime = now;
        currentX = scrollLeft + walk;
        updatePosition();
      }

      function onPointerUp(e: PointerEvent) {
        if (!isDragging) return;
        isDragging = false;
        carousel.classList.remove('is-dragging');
        carousel.releasePointerCapture(e.pointerId);
        momentumScroll();
      }

      carousel.addEventListener('pointerdown', onPointerDown);
      carousel.addEventListener('pointermove', onPointerMove);
      carousel.addEventListener('pointerup', onPointerUp);
      carousel.addEventListener('pointercancel', onPointerUp);
      carousel.addEventListener('pointerleave', onPointerUp);

      carousel.addEventListener('dragstart', (e) => e.preventDefault());
      carousel.addEventListener('contextmenu', (e) => e.preventDefault());

      let resizeTimeout: ReturnType<typeof setTimeout>;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(update3DEffect, 100);
      });

      requestAnimationFrame(update3DEffect);
    }

    // Initialize on load and navigation
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDraggableCarousel);
    } else {
      initDraggableCarousel();
    }
    document.addEventListener('astro:after-swap', initDraggableCarousel);

    // Animated Counter
    function animateCounters() {
      const counters = document.querySelectorAll('[data-count]');

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.count || '0');
            const suffix = el.dataset.suffix || '';
            const duration = 2000;
            const start = performance.now();

            function update(currentTime: number) {
              const elapsed = currentTime - start;
              const progress = Math.min(elapsed / duration, 1);

              // Ease out cubic
              const eased = 1 - Math.pow(1 - progress, 3);
              const current = Math.floor(eased * target);

              el.textContent = `${current}${suffix}`;

              if (progress < 1) {
                requestAnimationFrame(update);
              }
            }

            requestAnimationFrame(update);
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.7 });

      counters.forEach((counter) => observer.observe(counter));
    }

    // Initialize
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', animateCounters);
    } else {
      animateCounters();
    }

    document.addEventListener('astro:after-swap', animateCounters);

    // Hero Parallax Effect (Dennis Snellenberg style)
    function initParallax() {
      const parallaxElements = document.querySelectorAll('[data-parallax]');
      const floatingOrbs = document.querySelector('.floating-orbs');

      if (parallaxElements.length === 0 && !floatingOrbs) return;

      // Check for reduced motion
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) return;

      let ticking = false;

      function updateParallax() {
        const scrollY = window.scrollY;
        const windowHeight = window.innerHeight;

        // Parallax for elements with data-parallax
        parallaxElements.forEach((el) => {
          const element = el as HTMLElement;
          const speed = parseFloat(element.dataset.speed || '0.1');
          const yOffset = scrollY * speed;
          element.style.transform = `translateY(${yOffset}px)`;
        });

        // Subtle parallax for floating orbs
        if (floatingOrbs) {
          const orbsElement = floatingOrbs as HTMLElement;
          const orbOffset = scrollY * 0.05;
          orbsElement.style.transform = `translateY(${orbOffset}px)`;
        }

        ticking = false;
      }

      function onScroll() {
        if (!ticking) {
          requestAnimationFrame(updateParallax);
          ticking = true;
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });

      // Cleanup
      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', onScroll);
      }, { once: true });
    }

    // Initialize parallax
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initParallax);
    } else {
      initParallax();
    }

    document.addEventListener('astro:after-swap', initParallax);
    window.addEventListener('barba:afterEnter', initParallax);

    // Handle scroll to section when returning from case study
    function handleScrollToSection() {
      const section = sessionStorage.getItem('scrollToSection');
      if (section) {
        sessionStorage.removeItem('scrollToSection');
        // Wait for page to fully load, then scroll
        setTimeout(() => {
          const targetElement = document.getElementById(section);
          if (targetElement) {
            targetElement.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }, 100);
      }
    }

    // Run on load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', handleScrollToSection);
    } else {
      handleScrollToSection();
    }
  </script>

</BaseLayout>
