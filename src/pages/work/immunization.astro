---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

const metrics = [
  { value: '22% → 98%', label: 'Vaccinator attendance increase' },
  { value: '4,000+', label: 'Medical officers monitored' },
  { value: '3M', label: 'Children\'s records digitized' }
];

const contributions = [
  {
    label: 'Research',
    metrics: [
      { value: '3', text: 'government departments' },
      { value: '36', text: 'districts analyzed' },
      { value: '4,000+', text: 'medical officers studied' },
      { value: '2', text: 'pilot programs run' }
    ]
  },
  {
    label: 'Leadership',
    metrics: [
      { value: '3', text: 'departments coordinated' },
      { value: '1', text: 'CM Roadmap Team partnership' },
      { value: '£250k', text: 'DFID funding secured' },
      { value: '2', text: 'major products delivered' }
    ]
  },
  {
    label: 'Impact',
    metrics: [
      { value: '76%', text: 'attendance improvement' },
      { value: '3M', text: 'children\'s records digitized' },
      { value: '36', text: 'districts deployed' },
      { value: '4,000+', text: 'officers monitored' }
    ]
  }
];

const impactPoints = [
  {
    title: 'Two Products, One Mission',
    description: 'Led development of eVaccs 2.0 for real-time monitoring AND redesigned the national Child Vaccination Card with a companion Android app—digitizing records for 3 million children.'
  },
  {
    title: 'Designing for Constraints',
    description: 'Users had low literacy, basic phones, and spotty connectivity. Advocated for radical simplicity: one tap, GPS verification, offline-first. No typing required.'
  },
  {
    title: 'Cross-Department Coordination',
    description: 'Worked with Health, Irrigation, and Education departments plus the Chief Minister\'s Roadmap Team—gathering requirements, developing action plans, and meeting deadlines across multiple stakeholder groups.'
  },
  {
    title: 'Securing International Funding',
    description: 'The Child Vaccination Card project was awarded £250k by DFID (UK Department for International Development)—validating our approach and enabling province-wide rollout.'
  }
];

const constraints = [
  {
    constraint: 'Low Literacy',
    detail: 'Many vaccinators couldn\'t read — interfaces had to rely on icons, colors, and visual cues instead of text'
  },
  {
    constraint: 'Basic Devices',
    detail: 'Low-end Android phones with limited memory and processing power — every feature had to be lightweight'
  },
  {
    constraint: 'Unreliable Connectivity',
    detail: 'Rural areas with spotty network coverage — the app needed to work offline and sync when possible'
  },
  {
    constraint: 'Minimal Training',
    detail: 'No time for extensive onboarding — the interface had to be intuitive from first use'
  },
  {
    constraint: 'Resistance to Monitoring',
    detail: 'Vaccinators were wary of surveillance — the tool needed to feel helpful, not punitive'
  }
];

const designDecisions = [
  {
    title: 'Single-Tap Check-In',
    description: 'The core interaction was one tap at each vaccination site. GPS verification confirmed location automatically — no manual entry needed. Under 30 seconds per stop.'
  },
  {
    title: 'Visual-First Interface',
    description: 'Icons and color-coding replaced text wherever possible. Green checkmarks for completed stops, red alerts for missed ones. The interface worked for users who couldn\'t read.'
  },
  {
    title: 'Offline-First Architecture',
    description: 'All data stored locally and synced when connectivity was available. Essential for rural areas where network coverage was unpredictable.'
  },
  {
    title: 'Real-Time Supervisor Dashboard',
    description: 'District supervisors could see live maps of vaccinator locations, identify non-compliance immediately, and dispatch follow-ups the same day.'
  }
];

const learnings = [
  {
    title: 'Context beats features',
    description: 'The most sophisticated solution would have failed here. What worked was radical simplicity designed for real-world constraints.'
  },
  {
    title: 'Cross-department work requires translation',
    description: 'Working with Health, Irrigation, Education, and the CM Roadmap Team meant constantly translating technical capabilities into policy outcomes.'
  },
  {
    title: 'International funding validates approach',
    description: 'Securing £250k from DFID proved our methodology was sound—external validation that opened doors for province-wide expansion.'
  }
];
---

<CaseStudyLayout
  title="Immunization Tracker"
  subtitle="I led the redesign and development of eVaccs 2.0—a mobile monitoring system that transformed child vaccination coverage across Punjab, Pakistan's most populous province, increasing vaccinator attendance from 22% to 98%."
  description="Led development of eVaccs 2.0 and the national Child Vaccination Card digitization, monitoring 4,000+ medical officers and digitizing records for 3 million children."
  heroImage="/images/immunization/hero-image.png"
  industry="Public Health"
  role="Assistant Program Manager"
  timeline="2014-2015"
  platforms="Android Mobile, Web Dashboard"
  tools={[]}
  metrics={metrics}
  prevProject={{ title: 'Folio', href: '/work/folio' }}
  nextProject={{
    title: 'AI Lab',
    href: '/work/ai-lab',
    subtitle: 'Experiments in AI-assisted design and development'
  }}
>
  <!-- Section: The Challenge -->
  <section class="case-section">
    <h2>The Challenge</h2>
    <div class="problem-statement">
      <p class="lead-text">
        Child immunization in Punjab—Pakistan's most populous province—was failing. Only 22% of the 4,000+ medical officers were showing up to their assigned routes, and there was no way to track field activities.
      </p>
      <p class="lead-text secondary">
        Paper-based reporting was unreliable, easily falsified, and arrived weeks late. Meanwhile, children's vaccination records existed only on paper cards that were frequently lost or damaged.
      </p>
      <div class="challenge-box">
        <span class="challenge-label">The Problem</span>
        <p>
          The government needed <strong>real-time visibility into field operations</strong> and a way to digitize immunization records for millions of children—a dual challenge requiring coordination across Health, Irrigation, and Education departments.
        </p>
      </div>
    </div>
  </section>

  <!-- Section: My Contributions -->
  <section class="case-section">
    <h2>My Contributions</h2>
    <div class="contributions-stack">
      {contributions.map((contribution, index) => (
        <div class="contribution-row reveal">
          <span class="contribution-number">0{index + 1}</span>
          <div class="contribution-content">
            <h3 class="contribution-label">{contribution.label}</h3>
            <div class="contribution-metrics">
              {contribution.metrics.map((metric) => (
                <div class="contribution-metric">
                  <span class="metric-value">{metric.value}</span>
                  <span class="metric-text">{metric.text}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: How I Made an Impact -->
  <section class="case-section">
    <h2>How I Made an Impact</h2>
    <div class="impact-stack">
      {impactPoints.map((point, index) => (
        <div class="impact-row">
          <span class="impact-number">0{index + 1}</span>
          <div class="impact-content">
            <h3>{point.title}</h3>
            <p>{point.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Understanding Constraints -->
  <section class="case-section">
    <h2>Understanding Constraints</h2>
    <p class="section-intro">
      Before building anything, we needed to understand our users—vaccinators in rural areas with very different contexts than our own:
    </p>

    <div class="constraints-grid">
      {constraints.map(item => (
        <div class="constraint-card">
          <h3>{item.constraint}</h3>
          <p>{item.detail}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Key Decisions -->
  <section class="case-section">
    <h2>Key Decisions</h2>
    <p>
      Based on field research and stakeholder needs, we advocated for these core product decisions:
    </p>

    <div class="decisions-stack">
      {designDecisions.map((decision, index) => (
        <div class="decision-row">
          <span class="decision-number">0{index + 1}</span>
          <div class="decision-content">
            <h3>{decision.title}</h3>
            <p>{decision.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Stakeholder Management -->
  <section class="case-section">
    <h2>Stakeholder Management</h2>
    <blockquote class="stakeholder-quote">
      <p>
        "A critical part of this project was navigating government bureaucracy—translating technical capabilities into policy outcomes that politicians and bureaucrats could understand and champion."
      </p>
    </blockquote>

    <div class="stakeholder-details">
      <div class="stakeholder-item">
        <h3>Chief Minister Office</h3>
        <p>Prepared data-driven presentations demonstrating ROI and public health impact. Secured executive sponsorship for province-wide rollout.</p>
      </div>
      <div class="stakeholder-item">
        <h3>World Bank (PPMR Program)</h3>
        <p>Aligned project outcomes with funding requirements. Demonstrated measurable results that justified additional budget allocation.</p>
      </div>
      <div class="stakeholder-item">
        <h3>District Health Officers</h3>
        <p>Trained supervisors on dashboard usage and established feedback loops for continuous improvement.</p>
      </div>
    </div>
  </section>

  <!-- Section: Results -->
  <section class="case-section">
    <h2>Results</h2>
    <p>
      The impact was dramatic and measurable:
    </p>

    <div class="results-grid">
      <div class="result-card">
        <span class="result-value">22% → 98%</span>
        <span class="result-label">Vaccinator Attendance</span>
        <p>Real-time GPS tracking created accountability that paper reports never could</p>
      </div>
      <div class="result-card">
        <span class="result-value">3M</span>
        <span class="result-label">Children's Records Digitized</span>
        <p>National Child Vaccination Card redesign enabled province-wide digital records</p>
      </div>
      <div class="result-card">
        <span class="result-value">£250k</span>
        <span class="result-label">DFID Funding Awarded</span>
        <p>International validation of our approach from UK Department for International Development</p>
      </div>
    </div>
  </section>

  <!-- Section: Reflection -->
  <section class="case-section">
    <h2>Reflection</h2>
    <div class="reflections-container">
      <blockquote class="reflection-quote">
        <p>
          "This project taught me that great design isn't about features—it's about understanding constraints and designing within them. The technology was invisible; the outcome was what mattered."
        </p>
      </blockquote>

      <div class="learnings-stack">
        {learnings.map((learning, index) => (
          <div class="learning-row">
            <span class="learning-icon">0{index + 1}</span>
            <div class="learning-content">
              <h3>{learning.title}</h3>
              <p>{learning.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section: What This Shows About Me -->
  <section class="case-section conclusion">
    <h2>What This Shows About Me</h2>
    <p class="conclusion-intro">
      This project demonstrates my ability to lead complex, high-stakes initiatives from concept to scale—working with diverse stakeholders, constrained environments, and real-world impact.
    </p>

    <div class="about-me-stack">
      <div class="about-me-row">
        <h3>Cross-Functional Leadership</h3>
        <p>Led development of two major products (eVaccs 2.0 and Child Vaccination Card app) coordinating across Health, Irrigation, and Education departments.</p>
      </div>
      <div class="about-me-row">
        <h3>Designing for Constraints</h3>
        <p>Advocated for radical simplicity based on user research. The solution worked because it was designed for real-world limitations, not ideal conditions.</p>
      </div>
      <div class="about-me-row">
        <h3>Stakeholder Management</h3>
        <p>Worked with CM Roadmap Team consultants, secured £250k DFID funding, and coordinated requirements gathering across multiple government departments.</p>
      </div>
      <div class="about-me-row">
        <h3>Measurable Impact at Scale</h3>
        <p>Delivered results that mattered: 76% improvement in attendance (22% → 98%), 3 million children's records digitized, 4,000+ medical officers monitored.</p>
      </div>
    </div>
  </section>
</CaseStudyLayout>

<style>
