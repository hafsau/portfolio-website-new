---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

const metrics = [
  { value: '4+', label: 'Projects planned' },
  { value: '2026', label: 'Launch year' },
  { value: '100%', label: 'AI-assisted' }
];
---

<CaseStudyLayout
  title="AI Lab"
  subtitle="A collection of experiments exploring what's possible when a product designer teams up with AI. Each project started as a question: 'What if Claude Code could help me build this?'"
  description="Experiments in AI-assisted design and development using Claude Code"
  heroImage="/images/ai-lab/hero-image.svg"
  industry="AI / Design Tools"
  role="Designer & Developer"
  timeline="2026 - Ongoing"
  platforms="Web, iOS, Desktop"
  tools={[]}
  metrics={metrics}
  nextProject={{
    title: 'MedRec',
    href: '/work/medrec',
    subtitle: 'Streamlined diabetes management'
  }}
>
  <!-- Work in Progress Section -->
  <section class="case-section wip-section">
    <div class="wip-container">
      <!-- Lab Icon -->
      <div class="wip-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 3h6v2H9zM10 5v4.5l-4 6V21h12v-5.5l-4-6V5"/>
          <path d="M8.5 14h7"/>
          <circle cx="10" cy="17" r="1"/>
          <circle cx="14" cy="17" r="1"/>
        </svg>
      </div>

      <!-- WIP Badge -->
      <span class="wip-badge">Work in Progress</span>

      <!-- Main Message -->
      <h2 class="wip-heading">Experiments Coming Soon</h2>

      <p class="wip-description">
        This space is being prepared to showcase experiments in AI-assisted design and development.
        Each project explores what's possible when a product designer collaborates with tools like Claude Code.
      </p>

      <p class="wip-description secondary">
        Check back soon to see the full collection of projects, insights, and learnings.
      </p>

      <!-- Divider -->
      <div class="wip-divider"></div>

      <!-- CTA -->
      <p class="wip-cta-text">In the meantime, explore my other work:</p>
      <a href="/work/medrec" class="wip-cta-button">
        View Case Studies
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>
</CaseStudyLayout>

<style>
  /* Orange accent color for AI Lab */
  :global(:root) {
    --ai-lab-accent: #f97316;
  }

  /* WIP Section */
  .wip-section {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 0;
  }

  .wip-container {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
    background: var(--color-border);
    border-radius: 1.5rem;
    border: 1px solid rgba(249, 115, 22, 0.2);
  }

  .wip-icon {
    color: #f97316;
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .wip-icon svg {
    width: 64px;
    height: 64px;
  }

  .wip-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.5rem 1rem;
    background: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
  }

  .wip-heading {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-fg);
    margin-bottom: 1.5rem;
  }

  .wip-description {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .wip-description.secondary {
    margin-bottom: 2rem;
  }

  .wip-divider {
    width: 60px;
    height: 1px;
    background: var(--color-border);
    margin: 2rem auto;
  }

  .wip-cta-text {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .wip-cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: #f97316;
    color: white;
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .wip-cta-button:hover {
    background: #ea580c;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(249, 115, 22, 0.3);
  }

  .wip-cta-button svg {
    transition: transform 0.3s ease;
  }

  .wip-cta-button:hover svg {
    transform: translateX(4px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .wip-container {
      padding: 2rem 1.5rem;
      margin: 0 1rem;
    }

    .wip-icon svg {
      width: 48px;
      height: 48px;
    }

    .wip-heading {
      font-size: 1.5rem;
    }

    .wip-description {
      font-size: 1rem;
    }
  }
</style>
