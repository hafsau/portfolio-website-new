---
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';
import CodeTerminal from '../../components/CodeTerminal.astro';

const metrics = [
  { value: '4', label: 'Projects Shipped' },
  { value: '1', label: 'Hackathon Won' }
];

// Featured projects with detailed "messy middle" narrative
const featuredProjects = [
  {
    id: 'equaltales',
    title: 'EqualTales',
    tags: ['Claude', 'DALL-E', 'Next.js', 'Hackathon Winner'],
    image: '/images/ai-lab/equaltales.png',
    url: 'https://equaltales.vercel.app/',
    question: "Can AI create meaningful children's content that challenges stereotypes?",
    tool: { name: 'Claude + DALL-E' },
    challenge: "A hackathon challenge with a mission: create something that helps close the gender gap in STEM.",
    triedAndFailed: [
      "Generating unique characters per story—faces were inconsistent across pages",
      "Using photorealistic image style—uncanny valley effect",
      "Generic fictional role models—felt hollow without authenticity"
    ],
    whatWorked: [
      "Real historical women (Marie Curie, Mae Jemison) for instant authenticity",
      "Watercolor illustration style for cohesive, warm visuals",
      "Child's name woven into narrative for emotional connection"
    ],
    keyTradeoff: "Chose authenticity over flexibility—real historical figures limit story variety but create deeper emotional impact.",
    outcome: {
      award: "Best AI/ML — #75HER Hackathon",
      reach: "Demo'd to 200+ attendees"
    }
  },
  {
    id: 'portfolio',
    title: 'HafsaUsmani.com',
    tags: ['Claude Code', 'Cursor', 'Astro'],
    image: '/images/ai-lab/portfolio.png',
    url: 'https://hafsausmani.com/',
    question: "Can a designer build a custom portfolio without writing code from scratch?",
    tool: { name: 'Claude Code + Cursor' },
    challenge: "Create a portfolio that showcases both design sensibility and technical capability—standing out from template-based sites.",
    triedAndFailed: [
      "Using page builders—too generic, no custom interactions",
      "Hand-coding everything—too slow, constant context switching",
      "Off-the-shelf templates—couldn't showcase actual skills"
    ],
    whatWorked: [
      "Prompt-driven development with Claude Code for complex logic",
      "Iterative conversation to refine animations and effects",
      "Custom CSS over framework constraints for full control"
    ],
    keyTradeoff: "Chose custom build over speed—took longer but resulted in a portfolio that demonstrates the very skills it showcases.",
    outcome: {
      result: "Live portfolio with custom animations",
      tech: "Astro, Custom CSS, 3D card effects"
    }
  }
];

// Other experiments (compact format) - only Interview Sage and HeadshotAI
const labProjects = [
  {
    id: 'interview-sage',
    title: 'Interview Sage',
    tags: ['Replit Agent', 'AI Coach'],
    image: '/images/ai-lab/interview-sage.png',
    url: 'https://interview-sage--hafsausmani.replit.app/',
    question: "Can AI provide meaningful interview practice and feedback?",
    tool: 'Replit Agent',
    keyLearning: "Speed dramatically lowers the barrier to shipping useful products. Ideas don't have to stay ideas—they can become working tools."
  },
  {
    id: 'headshot-ai',
    title: 'HeadshotAI',
    tags: ['Lovable', 'Image Gen'],
    image: '/images/ai-lab/headshot-ai.png',
    url: 'https://heatshot-ai.lovable.app/',
    question: "Can no-code AI tools create professional-grade image applications?",
    tool: 'Lovable',
    keyLearning: "Visual builders force clearer thinking about user flow. Constraints aren't limitations—they're design decisions made for you."
  }
];

// Philosophy pillars - numbered, no emojis
const philosophy = [
  {
    number: '01',
    title: 'Intent First',
    description: 'Define the problem clearly before prompting. The better I articulate what I want, the better the output.'
  },
  {
    number: '02',
    title: 'Fast Loops',
    description: 'Prototype in hours, not weeks. Speed enables risk-taking—ambitious ideas become low-stakes experiments.'
  },
  {
    number: '03',
    title: 'Ship & Learn',
    description: 'Real users teach more than assumptions. Deploy early, gather feedback, iterate with purpose.'
  }
];

// AI Tools used - no emojis
const aiTools = [
  {
    name: 'Claude Code',
    bestFor: 'Complex codebases, debugging, architecture decisions',
    usedIn: ['HafsaUsmani.com'],
    learning: 'Pair programming with AI that understands context across files'
  },
  {
    name: 'Cursor',
    bestFor: 'In-editor assistance, quick edits, code completion',
    usedIn: ['HafsaUsmani.com'],
    learning: 'Best for iterative refinement when you know what you want'
  },
  {
    name: 'Replit Agent',
    bestFor: 'Rapid prototyping, full-stack MVPs',
    usedIn: ['Interview Sage'],
    learning: 'Lowest friction from idea to deployed app'
  },
  {
    name: 'Lovable',
    bestFor: 'Visual-first apps, no-code builds',
    usedIn: ['HeadshotAI'],
    learning: 'Perfect for validating ideas without writing code'
  },
  {
    name: 'DALL-E',
    bestFor: 'Image generation, visual prototypes, illustrations',
    usedIn: ['EqualTales'],
    learning: 'Style consistency requires careful prompting and iteration'
  },
  {
    name: 'v0 by Vercel',
    bestFor: 'UI component generation, React prototypes',
    usedIn: ['Experiments'],
    learning: 'Great for quickly visualizing component ideas before building'
  }
];

// Currently exploring
const exploring = [
  {
    title: 'AI Agents for Design',
    status: 'wip',
    description: 'Building autonomous assistants for design system maintenance'
  },
  {
    title: 'Design-to-Code Workflows',
    status: 'wip',
    description: 'Figma to production code with AI translation'
  },
  {
    title: 'AI for Accessibility',
    status: 'idea',
    description: 'Automated accessibility checking and fix suggestions'
  }
];

// Enhanced reflections with before/after examples
const reflections = [
  {
    title: 'Prompting is a Design Skill',
    description: 'The quality of AI output directly reflects the clarity of input.',
    before: '"Make me a login page"',
    after: '"Create a login page for elderly users with high contrast, 18px min font, single-column layout, and clear error states"'
  },
  {
    title: 'Speed Changes What\'s Possible',
    description: 'When building takes hours instead of weeks, you can chase ideas that seemed too risky before.'
  },
  {
    title: 'AI Amplifies, Not Replaces',
    description: 'Every project still required design decisions: What problem matters? What flow feels right? AI handled implementation; I owned the intent.'
  }
];
---

<CaseStudyLayout
  title="AI Lab"
  subtitle="Where a product designer learns to ship code. Each project started as a question—and ended with a working prototype."
  description="Experiments in AI-assisted design and development using Claude Code, Replit, and other AI tools"
  heroImage="/images/ai-lab/hero-image.svg"
  industry="AI / Design Tools"
  role="Designer, Developer & Builder"
  timeline="2025 - Ongoing"
  platforms="Web"
  tools={[]}
  metrics={metrics}
  nextProject={{
    title: 'MedRec',
    href: '/work/medrec',
    subtitle: 'Streamlined diabetes management'
  }}
>
  <!-- Section: Code Terminal Intro -->
  <section class="case-section terminal-intro">
    <CodeTerminal prompts={[
      "claude: Build a storybook generator",
      "claude: Use watercolor illustration style",
      "claude: Add child name personalization",
      "claude: Feature real historical women"
    ]} />
    <p class="terminal-caption">This is how it starts. A question, a prompt, and curiosity.</p>
  </section>

  <!-- Section: Philosophy -->
  <section class="case-section">
    <h2>My Approach</h2>
    <p class="philosophy-intro">
      I don't use AI to skip the design process—I use it to iterate faster on more ambitious ideas.
    </p>
    <div class="philosophy-grid">
      {philosophy.map(pillar => (
        <div class="philosophy-card">
          <span class="philosophy-number">{pillar.number}</span>
          <h3>{pillar.title}</h3>
          <p>{pillar.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Featured Projects -->
  {featuredProjects.map((project, index) => (
    <section id={project.id} class="case-section featured-project-section">
      <div class="featured-header">
        <span class="featured-badge">Featured Project {index + 1}</span>
        <h2>{project.title}</h2>
        <p class="featured-question">{project.question}</p>
      </div>

      <div class="featured-meta">
        <div class="featured-meta-item">
          <span class="meta-label">Tools</span>
          <span class="meta-value">{project.tool.name}</span>
        </div>
        {project.outcome.award && (
          <div class="featured-meta-item">
            <span class="meta-label">Outcome</span>
            <span class="meta-value">{project.outcome.award}</span>
          </div>
        )}
        {project.outcome.result && (
          <div class="featured-meta-item">
            <span class="meta-label">Result</span>
            <span class="meta-value">{project.outcome.result}</span>
          </div>
        )}
        <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link featured-link">
          View Live
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>

      <div class="featured-image">
        <img src={project.image} alt={`${project.title} - AI-assisted project preview`} />
      </div>

      <div class="featured-narrative">
        <div class="narrative-block challenge-block">
          <h4>The Challenge</h4>
          <p>{project.challenge}</p>
        </div>

        <div class="narrative-block decision-card">
          <div class="decision-column failed">
            <h4>What I Tried That Didn't Work</h4>
            <ul>
              {project.triedAndFailed.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
          <div class="decision-column worked">
            <h4>What Actually Worked</h4>
            <ul>
              {project.whatWorked.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        </div>

        <div class="narrative-block tradeoff-block">
          <h4>Key Trade-off</h4>
          <blockquote>{project.keyTradeoff}</blockquote>
        </div>
      </div>
    </section>
  ))}

  <!-- Section: Other Experiments -->
  <section class="case-section experiments-section">
    <h2>Other Experiments</h2>
    <p class="section-intro">
      Quick builds that validated ideas and taught lessons.
    </p>
    <div class="experiments-grid">
      {labProjects.map(project => (
        <div id={project.id} class="experiment-card">
          <div class="experiment-image">
            <img src={project.image} alt={`${project.title} - AI-assisted project preview`} />
          </div>
          <div class="experiment-content">
            <div class="experiment-header">
              <h3>{project.title}</h3>
              <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
                View Live
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
            <p class="experiment-question">{project.question}</p>
            <div class="experiment-meta">
              <span class="experiment-tool">{project.tool}</span>
            </div>
            <p class="experiment-learning">{project.keyLearning}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: AI Toolbox -->
  <section class="case-section toolbox-section">
    <h2>AI Toolbox</h2>
    <p class="section-intro">
      Different tools for different jobs. Here's what I've learned about each.
    </p>
    <div class="toolbox-grid">
      {aiTools.map(tool => (
        <div class="tool-card">
          <div class="tool-header">
            <h3>{tool.name}</h3>
          </div>
          <div class="tool-best-for">
            <span class="tool-label">Best for:</span>
            <span>{tool.bestFor}</span>
          </div>
          <p class="tool-learning">{tool.learning}</p>
          <div class="tool-used-in">
            {tool.usedIn.map(project => (
              <span class="tool-project-tag">{project}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: What I've Learned -->
  <section class="case-section reflections-section">
    <h2>What I've Learned</h2>
    <div class="reflections-grid">
      {reflections.map((reflection, index) => (
        <div class="reflection-card">
          <span class="reflection-number">0{index + 1}</span>
          <div class="reflection-content">
            <h3>{reflection.title}</h3>
            <p>{reflection.description}</p>
            {reflection.before && reflection.after && (
              <div class="before-after">
                <div class="before">
                  <span class="ba-label">Before</span>
                  <code>{reflection.before}</code>
                </div>
                <div class="after">
                  <span class="ba-label">After</span>
                  <code>{reflection.after}</code>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Section: Currently Exploring -->
  <section class="case-section">
    <h2>Currently Exploring</h2>
    <p class="section-intro">
      Work in progress. Ideas taking shape.
    </p>
    <div class="exploring-grid">
      {exploring.map(item => (
        <div class="exploring-card">
          <div class="exploring-header">
            <span class={`status-badge status-${item.status}`}>
              {item.status === 'wip' ? 'In Progress' : 'Idea'}
            </span>
            <h3>{item.title}</h3>
          </div>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
    <div class="exploring-cta">
      <p>Have a project idea? <a href="/#contact">Let's chat.</a></p>
    </div>
  </section>
</CaseStudyLayout>

<style>
  /* Orange accent color override for AI Lab */
  :global(:root) {
    --ai-lab-accent: #f97316;
  }

  h2 {
    color: var(--color-fg);
  }

  .reflection-number,
  .lab-tag {
    color: #f97316;
  }

  /* Terminal Intro Section */
  .terminal-intro {
    text-align: center;
    padding-bottom: 2rem;
  }

  .terminal-caption {
    margin-top: 1.5rem;
    color: var(--color-muted);
    font-style: italic;
    font-size: 1rem;
  }

  /* Philosophy Section */
  .philosophy-intro {
    font-size: 1.25rem;
    color: var(--color-fg);
    margin-bottom: 2rem;
    font-style: italic;
    border-left: 3px solid #f97316;
    padding-left: 1.5rem;
  }

  .philosophy-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .philosophy-card {
    background: var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-left: 3px solid #f97316;
  }

  .philosophy-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(249, 115, 22, 0.1);
  }

  .philosophy-number {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: #f97316;
    display: block;
    margin-bottom: 0.75rem;
  }

  .philosophy-card h3 {
    font-size: 1.125rem;
    color: var(--color-fg);
    margin-bottom: 0.5rem;
  }

  .philosophy-card p {
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
    font-size: 0.9375rem;
  }

  /* Featured Project Section */
  .featured-project-section {
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .featured-header {
    margin-bottom: 1.5rem;
  }

  .featured-badge {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #f97316;
    background: rgba(249, 115, 22, 0.1);
    padding: 0.375rem 0.75rem;
    border-radius: 1rem;
    margin-bottom: 1rem;
  }

  .featured-header h2 {
    margin-bottom: 0.5rem;
  }

  .featured-question {
    font-size: 1.125rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
    align-items: center;
  }

  .featured-meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
  }

  .meta-value {
    color: var(--color-fg);
    font-weight: 500;
  }

  .featured-link {
    margin-left: auto;
  }

  .featured-image {
    margin-bottom: 2rem;
    border-radius: 1rem;
    overflow: hidden;
    background: #1a1a24;
  }

  .featured-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .featured-narrative {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .narrative-block {
    background: var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .narrative-block h4 {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .challenge-block p {
    color: var(--color-fg);
    line-height: 1.6;
    margin: 0;
    font-size: 1.0625rem;
  }

  .decision-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 0;
    background: transparent;
  }

  .decision-column {
    background: var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
  }

  .decision-column.failed {
    border-left: 3px solid #ef4444;
  }

  .decision-column.failed h4 {
    color: #ef4444;
  }

  .decision-column.worked {
    border-left: 3px solid #22c55e;
  }

  .decision-column.worked h4 {
    color: #22c55e;
  }

  .decision-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .decision-column li {
    color: var(--color-fg);
    line-height: 1.6;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .decision-column li:last-child {
    border-bottom: none;
  }

  .tradeoff-block blockquote {
    margin: 0;
    font-size: 1.0625rem;
    font-style: italic;
    color: var(--color-fg);
    line-height: 1.6;
    border-left: 3px solid #f97316;
    padding-left: 1rem;
  }

  /* Other Experiments */
  .experiments-grid {
    display: grid;
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .experiment-card {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    background: var(--color-border);
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .experiment-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
  }

  .experiment-image {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #1a1a24;
  }

  .experiment-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: transform 0.3s ease;
  }

  .experiment-card:hover .experiment-image img {
    transform: scale(1.05);
  }

  .experiment-content {
    padding: 1.5rem 1.5rem 1.5rem 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0; /* Allow content to shrink */
  }

  .experiment-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }

  .experiment-header h3 {
    font-size: 1.25rem;
    color: var(--color-fg);
    margin: 0;
  }

  .experiment-question {
    font-style: italic;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
    word-wrap: break-word;
  }

  .experiment-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .experiment-tool {
    font-size: 0.8125rem;
    color: #f97316;
    background: rgba(249, 115, 22, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
  }

  .experiment-learning {
    color: var(--color-fg);
    line-height: 1.6;
    margin: 0;
    font-size: 0.9375rem;
    word-wrap: break-word;
  }

  /* Project Link */
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    padding: 0.25rem 0.75rem;
    background: transparent;
    border: 1px solid #f97316;
    border-radius: 1rem;
    color: #f97316;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .project-link:hover {
    background: #f97316;
    color: white;
  }

  /* AI Toolbox */
  .toolbox-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .tool-card {
    background: var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(249, 115, 22, 0.1);
  }

  .tool-header {
    margin-bottom: 1rem;
  }

  .tool-header h3 {
    font-size: 1.125rem;
    color: var(--color-fg);
    margin: 0;
  }

  .tool-best-for {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  .tool-label {
    color: #f97316;
    font-weight: 500;
    margin-right: 0.25rem;
  }

  .tool-learning {
    color: var(--color-fg);
    line-height: 1.6;
    margin-bottom: 1rem;
    font-size: 0.9375rem;
  }

  .tool-used-in {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tool-project-tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0.5rem;
    color: var(--color-muted);
  }

  /* Other Experiments Section - extra spacing after featured projects */
  .experiments-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
