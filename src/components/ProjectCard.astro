---
interface Props {
  title: string;
  subtitle: string;
  metric: string;
  metricLabel: string;
  href: string;
  image?: string;
  tags?: string[];
}

const { title, subtitle, metric, metricLabel, href, image, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block bg-[var(--color-card)] border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-[var(--color-accent)] transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
>
  <!-- Image placeholder -->
  <div class="aspect-[16/10] bg-[var(--color-border)] relative overflow-hidden">
    {image ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-[var(--color-muted)]">
        <svg class="w-16 h-16 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}

    <!-- Metric badge -->
    <div class="absolute bottom-4 left-4 bg-[var(--color-background)]/90 backdrop-blur-sm px-3 py-1.5 rounded-full">
      <span class="text-sm font-semibold text-[var(--color-accent)]">{metric}</span>
      <span class="text-xs text-[var(--color-muted)] ml-1">{metricLabel}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <h3 class="font-semibold text-lg mb-1 group-hover:text-[var(--color-accent)] transition-colors">
      {title}
    </h3>
    <p class="text-[var(--color-muted)] text-sm mb-4">
      {subtitle}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="text-xs px-2 py-1 bg-[var(--color-border)] rounded-md text-[var(--color-muted)]">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
