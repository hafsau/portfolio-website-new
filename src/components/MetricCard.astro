---
interface Props {
  value: string;
  label: string;
}

const { value, label } = Astro.props;
---

<div class="text-center p-6 bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl">
  <div class="text-3xl md:text-4xl font-bold text-[var(--color-accent)] mb-2">
    {value}
  </div>
  <div class="text-sm text-[var(--color-muted)]">
    {label}
  </div>
</div>
