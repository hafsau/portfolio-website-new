---
import BaseLayout from './BaseLayout.astro';
import Lightbox from '../components/Lightbox.astro';
import AmbientBackground from '../components/AmbientBackground.astro';
import MobileNav from '../components/MobileNav.astro';

interface Metric {
  value: string;
  label: string;
}

interface ProjectLink {
  title: string;
  href: string;
  subtitle?: string;
  image?: string;
}

interface Props {
  title: string;
  subtitle: string;
  description: string;
  heroImage?: string;
  industry: string;
  role: string;
  timeline: string;
  platforms?: string;
  tools: string[];
  metrics: Metric[];
  prevProject?: ProjectLink;
  nextProject?: ProjectLink;
}

const {
  title,
  subtitle,
  description,
  heroImage,
  industry,
  role,
  timeline,
  platforms,
  tools,
  metrics,
  prevProject,
  nextProject
} = Astro.props;

const siteUrl = 'https://hafsausmani.com';
const fullHeroImage = heroImage ? (heroImage.startsWith('http') ? heroImage : `${siteUrl}${heroImage}`) : undefined;

// JSON-LD Schemas
const creativeWorkSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": title,
  "description": description,
  "image": fullHeroImage,
  "author": {
    "@type": "Person",
    "name": "Hafsa Usmani"
  },
  "datePublished": timeline
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Work", "item": `${siteUrl}/work` },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
};
---

<BaseLayout title={title} description={description} ogImage={heroImage} ogType="article" useBarba={false}>
  <!-- Page Transition Overlay with Curved SVG -->
  <div class="page-transition-overlay" id="page-transition">
    <div class="transition-background"></div>
    <div class="transition-curve">
      <svg viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0,0 L0,70 Q50,100 100,70 L100,0 Z" />
      </svg>
    </div>
    <div class="transition-content">
      <span class="transition-label">Loading</span>
      <h1 class="transition-title">{title}</h1>
    </div>
  </div>

  <!-- JSON-LD Structured Data for Case Study -->
  <script type="application/ld+json" set:html={JSON.stringify(creativeWorkSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Ambient Background -->
  <AmbientBackground variant="subtle" />

  <!-- Lightbox (global) -->
  <Lightbox />

  <!-- Cursor Dot Follower -->
  <div class="cursor-dot" id="cursor-dot">
    <div class="cursor-ring"></div>
    <span class="cursor-text" id="cursor-text"></span>
  </div>

  <!-- Navigation -->
  <nav class="nav-fixed">
    <div class="scroll-progress" id="scroll-progress"></div>
    <div class="container py-5 flex items-center justify-between">
      <a href="/" class="signature-logo">
        <svg class="signature-svg" viewBox="0 0 90 28" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path class="sig-letter" d="M2 2v24M2 14h14M16 2v24"/>
          <path class="sig-letter" d="M30 2 L30 20 Q30 26 44 26 L44 2"/>
          <circle class="sig-dot" cx="62" cy="22" r="5"/>
        </svg>
      </a>
      <div class="nav-links-desktop">
        <a href="/" class="nav-home-link" data-section="home" data-cursor-text="Go">Home</a>
        <a href="/" class="nav-home-link" data-section="work" data-cursor-text="Go">Work</a>
        <a href="/" class="nav-home-link" data-section="about" data-cursor-text="Go">About</a>
        <a href="/" class="nav-home-link" data-section="contact" data-cursor-text="Go">Contact</a>
      </div>
      <MobileNav />
    </div>
  </nav>

  <article id="main-content" class="case-study">
    <!-- Header Section -->
    <header class="case-hero">
      <div class="container">
        <!-- Back link -->
        <a href="/#work" class="back-link reveal">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Back to Work
        </a>

        <!-- Title & Subtitle -->
        <div class="case-hero-content">
          <h1 class="case-title reveal delay-1">{title}</h1>
          <p class="case-subtitle reveal delay-2">{subtitle}</p>
        </div>

        <!-- Project Details Grid -->
        <div class="details-grid reveal delay-3">
          <div class="detail-item">
            <span class="detail-label">Industry</span>
            <span class="detail-value">{industry}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Role</span>
            <span class="detail-value">{role}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Year</span>
            <span class="detail-value">{timeline}</span>
          </div>
          {platforms && (
            <div class="detail-item">
              <span class="detail-label">Platform</span>
              <span class="detail-value">{platforms}</span>
            </div>
          )}
          {tools && tools.length > 0 && (
            <div class="detail-item">
              <span class="detail-label">Tools</span>
              <span class="detail-value">{tools.join(', ')}</span>
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- Hero Image (after details) -->
    <div class="container mb-12 reveal delay-4">
      <div class="case-hero-image">
        {heroImage ? (
          <img
            src={heroImage}
            alt={`${title} case study hero image - ${subtitle}`}
            class="w-full h-full object-contain"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            sizes="(max-width: 768px) 100vw, (max-width: 1200px) 80vw, 1200px"
          />
        ) : (
          <div class="case-hero-placeholder">
            <span class="text-muted text-sm">Project Preview</span>
          </div>
        )}
      </div>
    </div>

    <!-- High-Impact Results (no gray boxes) -->
    <div class="container mb-16">
      <div class="metrics-row reveal">
        {metrics.map((metric, index) => (
          <div class="metric-item">
            <span class="metric-number counter" data-target={metric.value}>{metric.value}</span>
            <span class="metric-desc">{metric.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Main Content -->
    <div class="case-content">
      <div class="container-narrow">
        <slot />
      </div>
    </div>

    <!-- Project Navigation -->
    <div class="project-nav-section">
      <div class="container">
        <!-- Utility Row: Previous + View All -->
        <div class="nav-utility-row reveal">
          {prevProject ? (
            <a href={prevProject.href} class="nav-util-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
              </svg>
              <span>Previous</span>
            </a>
          ) : (
            <span></span>
          )}
          <a href="/#work" class="nav-util-link">
            <span>View All Work</span>
          </a>
        </div>

        <!-- Next Project Feature -->
        {nextProject && (
          <a href={nextProject.href} class="next-project-feature reveal">
            <span class="next-label">Next Project</span>
            <h2 class="next-title">{nextProject.title}</h2>
            {nextProject.subtitle && (
              <p class="next-subtitle">{nextProject.subtitle}</p>
            )}
            <span class="next-cta">
              View Project
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>
        )}
      </div>
    </div>
  </article>

  <!-- Footer -->
  <footer class="py-8">
    <div class="container">
      <div class="divider mb-8"></div>
      <div class="flex items-center justify-between">
        <span class="text-small text-muted">&copy; 2026 Hafsa Usmani</span>
        <span class="text-small text-muted">SF Bay Area</span>
      </div>
    </div>
  </footer>

  <script>
    // Page Transition Animation with Curved SVG
    function animatePageTransition() {
      const pageTransition = document.getElementById('page-transition');
      const transitionCurve = pageTransition?.querySelector('.transition-curve') as HTMLElement;
      const transitionContent = pageTransition?.querySelector('.transition-content') as HTMLElement;
      const mainContent = document.getElementById('main-content');

      if (pageTransition && transitionCurve) {
        // Hide main content initially
        if (mainContent) {
          mainContent.style.opacity = '0';
          mainContent.style.transition = 'none';
        }

        // Reset transition for animation - curve starts covering the screen
        pageTransition.style.display = 'flex';
        transitionCurve.style.transform = 'translateY(0)';
        transitionCurve.style.transition = 'none';
        if (transitionContent) {
          transitionContent.style.opacity = '1';
          transitionContent.style.transition = 'none';
        }

        // Animate out after showing the title
        setTimeout(() => {
          // Fade out transition content
          if (transitionContent) {
            transitionContent.style.transition = 'opacity 0.4s ease-out';
            transitionContent.style.opacity = '0';
          }

          // Slide the curve up with a smooth ease
          setTimeout(() => {
            transitionCurve.style.transition = 'transform 1.2s cubic-bezier(0.65, 0, 0.35, 1)';
            transitionCurve.style.transform = 'translateY(-115%)';
          }, 300);

          // Show main content after curve starts moving
          setTimeout(() => {
            if (mainContent) {
              mainContent.style.transition = 'opacity 0.6s ease-out';
              mainContent.style.opacity = '1';
            }
          }, 800);

          // Hide overlay after animation completes
          setTimeout(() => {
            pageTransition.style.display = 'none';
            // Reset for next use
            transitionCurve.style.transform = 'translateY(0)';
            if (transitionContent) transitionContent.style.opacity = '1';
          }, 1600);
        }, 600);
      }
    }

    // Run on initial page load
    animatePageTransition();

    // Re-run after View Transitions navigation
    document.addEventListener('astro:after-swap', animatePageTransition);

    // Handle navigation to home page with curved transition
    function setupHomeNavigation() {
      const homeLinks = document.querySelectorAll('.nav-home-link, .back-link, .signature-logo');
      const pageTransition = document.getElementById('page-transition');
      const transitionCurve = pageTransition?.querySelector('.transition-curve') as HTMLElement;

      homeLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const section = link.getAttribute('data-section') || 'home';

          // Show transition overlay (curve slides up from bottom)
          if (pageTransition && transitionCurve) {
            pageTransition.style.display = 'flex';
            pageTransition.classList.add('active');

            // Start curve below the viewport
            transitionCurve.style.transform = 'translateY(110%)';
            transitionCurve.style.transition = 'none';

            // Update transition title for going home
            const titleEl = pageTransition.querySelector('.transition-title');
            const labelEl = pageTransition.querySelector('.transition-label');
            const contentEl = pageTransition.querySelector('.transition-content') as HTMLElement;
            if (titleEl) titleEl.textContent = 'Home';
            if (labelEl) labelEl.textContent = 'Returning to';
            if (contentEl) {
              contentEl.style.opacity = '0';
              contentEl.style.transition = 'none';
            }

            requestAnimationFrame(() => {
              // Animate curve sliding up to cover screen
              transitionCurve.style.transition = 'transform 0.6s cubic-bezier(0.76, 0, 0.24, 1)';
              transitionCurve.style.transform = 'translateY(0)';

              // Fade in content
              if (contentEl) {
                setTimeout(() => {
                  contentEl.style.transition = 'opacity 0.3s ease-in';
                  contentEl.style.opacity = '1';
                }, 200);
              }
            });

            // Navigate after animation
            setTimeout(() => {
              // Store section to scroll to
              sessionStorage.setItem('scrollToSection', section);
              window.location.href = '/';
            }, 600);
          } else {
            sessionStorage.setItem('scrollToSection', section);
            window.location.href = '/';
          }
        });
      });
    }

    setupHomeNavigation();

    // Initialize all page functionality
    function initCaseStudyPage() {
      // Scroll Progress and Nav Background
      const scrollProgress = document.getElementById('scroll-progress');
      const navFixed = document.querySelector('.nav-fixed');

      function updateScrollProgress() {
        const scrollTop = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollTop / docHeight;
        if (scrollProgress) {
          scrollProgress.style.transform = `scaleX(${progress})`;
        }
        // Add scrolled class after scrolling past 50px
        if (navFixed) {
          if (scrollTop > 50) {
            navFixed.classList.add('scrolled');
          } else {
            navFixed.classList.remove('scrolled');
          }
        }
      }

      window.addEventListener('scroll', updateScrollProgress);
      updateScrollProgress();

      // Scroll Reveal
      const observerOptions = {
        root: null,
        rootMargin: '-50px',
        threshold: 0.3
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, observerOptions);

      document.querySelectorAll('.reveal, .words-reveal, .text-reveal, .chars-reveal, .stagger-grid').forEach(el => {
        observer.observe(el);
      });

      // Cursor Dot Follower
      const cursorDot = document.getElementById('cursor-dot');
      const cursorText = document.getElementById('cursor-text');
      let mouseX = 0;
      let mouseY = 0;
      let dotX = 0;
      let dotY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        if (cursorDot && !cursorDot.classList.contains('visible')) {
          cursorDot.classList.add('visible');
        }
      });

      document.addEventListener('mouseleave', () => {
        if (cursorDot) {
          cursorDot.classList.remove('visible');
        }
      });

      function animateCursor() {
        dotX += (mouseX - dotX) * 0.15;
        dotY += (mouseY - dotY) * 0.15;
        if (cursorDot) {
          cursorDot.style.left = dotX + 'px';
          cursorDot.style.top = dotY + 'px';
        }
        requestAnimationFrame(animateCursor);
      }
      animateCursor();

      // Cursor text elements (like "Go" on nav links)
      const cursorTextElements = document.querySelectorAll('[data-cursor-text]');
      cursorTextElements.forEach((el) => {
        el.addEventListener('mouseenter', () => {
          const text = el.getAttribute('data-cursor-text');
          if (text && cursorText) {
            cursorText.textContent = text;
            cursorDot?.classList.add('has-text');
          }
        });
        el.addEventListener('mouseleave', () => {
          if (cursorText) cursorText.textContent = '';
          cursorDot?.classList.remove('has-text');
        });
      });

      // Hover effect on interactive elements
      const interactiveElements = document.querySelectorAll('a, button, .metric-item');
      interactiveElements.forEach(el => {
        if (!el.hasAttribute('data-cursor-text')) {
          el.addEventListener('mouseenter', () => {
            cursorDot?.classList.add('hover');
          });
          el.addEventListener('mouseleave', () => {
            cursorDot?.classList.remove('hover');
          });
        }
      });

      // Animated Counters
      const counters = document.querySelectorAll('.counter');
      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !entry.target.classList.contains('counted')) {
            entry.target.classList.add('counted');
            animateCounter(entry.target as HTMLElement);
          }
        });
      }, { threshold: 0.7 });

      function animateCounter(el: HTMLElement) {
        const target = el.dataset.target || '0';
        const hasPercent = target.includes('%');
        const hasX = target.includes('x');
        const hasPlus = target.includes('+');
        const numericValue = parseFloat(target.replace(/[^0-9.]/g, ''));
        const isDecimal = target.includes('.');
        const duration = 2000;
        const startTime = performance.now();

        // Check for reduced motion preference
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          el.textContent = target;
          return;
        }

        el.textContent = '0' + (hasPercent ? '%' : hasX ? 'x' : hasPlus ? '+' : '');

        function updateCounter(currentTime: number) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          // Ease out cubic for smooth deceleration
          const easeOut = 1 - Math.pow(1 - progress, 3);
          const currentValue = numericValue * easeOut;

          if (isDecimal) {
            el.textContent = currentValue.toFixed(1) + (hasX ? 'x' : hasPercent ? '%' : hasPlus ? '+' : '');
          } else {
            el.textContent = Math.floor(currentValue) + (hasPercent ? '%' : hasX ? 'x' : hasPlus ? '+' : '');
          }

          if (progress < 1) {
            requestAnimationFrame(updateCounter);
          } else {
            el.textContent = target;
          }
        }

        requestAnimationFrame(updateCounter);
      }

      counters.forEach(counter => counterObserver.observe(counter));

      // Drag cursor for images
      initImageDragCursor();
    }

    // Drag cursor for BeforeAfterSlider only (not regular images)
    function initImageDragCursor() {
      const caseContent = document.querySelector('.case-content');
      if (!caseContent) return;

      // Only target BeforeAfterSlider containers
      const sliders = caseContent.querySelectorAll('[data-ba-slider]');
      if (sliders.length === 0) return;

      // Create drag cursor element
      let dragCursor = document.getElementById('image-drag-cursor');
      if (!dragCursor) {
        dragCursor = document.createElement('div');
        dragCursor.id = 'image-drag-cursor';
        dragCursor.textContent = 'Drag';
        dragCursor.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          pointer-events: none;
          z-index: 99999;
          display: flex;
          align-items: center;
          justify-content: center;
          width: 80px;
          height: 80px;
          background: #4a5ee4;
          color: #fff;
          border-radius: 50%;
          font-size: 13px;
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 1px;
          font-family: 'Space Grotesk', sans-serif;
          opacity: 0;
          transform: translate(-50%, -50%) scale(0.5);
          transition: opacity 0.3s ease, transform 0.3s ease;
        `;
        document.body.appendChild(dragCursor);
      }

      let mouseX = 0, mouseY = 0;
      let cursorX = 0, cursorY = 0;

      // Smooth cursor following
      function animateDragCursor() {
        cursorX += (mouseX - cursorX) * 0.15;
        cursorY += (mouseY - cursorY) * 0.15;
        if (dragCursor) {
          dragCursor.style.left = cursorX + 'px';
          dragCursor.style.top = cursorY + 'px';
        }
        requestAnimationFrame(animateDragCursor);
      }
      animateDragCursor();

      function showDragCursor() {
        if (dragCursor) {
          dragCursor.style.opacity = '1';
          dragCursor.style.transform = 'translate(-50%, -50%) scale(1)';
        }
        const cursorDot = document.getElementById('cursor-dot');
        if (cursorDot) cursorDot.style.opacity = '0';
      }

      function hideDragCursor() {
        if (dragCursor) {
          dragCursor.style.opacity = '0';
          dragCursor.style.transform = 'translate(-50%, -50%) scale(0.5)';
        }
        const cursorDot = document.getElementById('cursor-dot');
        if (cursorDot) cursorDot.style.opacity = '1';
      }

      function trackMouse(e: MouseEvent) {
        mouseX = e.clientX;
        mouseY = e.clientY;
      }

      // Apply only to slider containers (BeforeAfterSlider)
      sliders.forEach(slider => {
        (slider as HTMLElement).style.cursor = 'none';
        slider.addEventListener('mouseenter', showDragCursor);
        slider.addEventListener('mouseleave', hideDragCursor);
        slider.addEventListener('mousemove', trackMouse as EventListener);
      });
    }

    // Run initialization
    initCaseStudyPage();

    // Re-initialize after View Transitions
    document.addEventListener('astro:after-swap', initCaseStudyPage);
  </script>

  <style>
    /* Page Transition Overlay with Curved SVG */
    .page-transition-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      overflow: hidden;
    }

    .transition-background {
      position: absolute;
      inset: 0;
      background: #0C0C0C;
      opacity: 0;
    }

    .page-transition-overlay.active .transition-background {
      opacity: 1;
    }

    .transition-curve {
      position: absolute;
      width: 100%;
      height: 115%;
      bottom: 0;
      left: 0;
      will-change: transform;
    }

    .transition-curve svg {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      fill: var(--color-accent);
    }

    /* Fixed Navigation */
    .nav-fixed {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: transparent;
      transition: background 0.3s ease, backdrop-filter 0.3s ease;
    }

    .nav-fixed.scrolled {
      background: rgba(12, 12, 12, 0.8);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .nav-fixed .container {
      padding-top: 1.25rem;
      padding-bottom: 1.25rem;
    }

    .nav-links-desktop {
      display: none;
      gap: 2.5rem;
    }

    @media (min-width: 768px) {
      .nav-links-desktop {
        display: flex;
      }
    }

    .nav-links-desktop a {
      color: var(--color-muted);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 0.75rem;
      text-decoration: none;
      position: relative;
      transition: color 0.2s ease;
    }

    .nav-links-desktop a::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 100%;
      height: 1px;
      background: var(--color-fg);
      transform: scaleX(0);
      transform-origin: right center;
      transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1);
    }

    .nav-links-desktop a:hover {
      color: var(--color-fg);
    }

    .nav-links-desktop a:hover::after {
      transform: scaleX(1);
      transform-origin: left center;
    }

    .scroll-progress {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 2px;
      width: 100%;
      background: var(--color-accent);
      transform-origin: left;
      transform: scaleX(0);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .nav-fixed.scrolled .scroll-progress {
      opacity: 1;
    }

    .transition-content {
      position: relative;
      z-index: 10;
      text-align: center;
      color: white;
    }

    .transition-label {
      display: block;
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      opacity: 0.7;
      margin-bottom: 0.75rem;
    }

    .transition-title {
      font-size: clamp(2rem, 8vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0;
    }

    /* Case Study Layout */
    .case-study {
      padding-top: 100px;
      opacity: 0;
    }

    .case-hero {
      padding: var(--space-lg) 0 var(--space-md);
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--color-muted);
      margin-bottom: var(--space-md);
      transition: color 0.2s ease;
    }

    .back-link:hover {
      color: var(--color-fg);
    }

    .case-hero-content {
      max-width: 800px;
      margin-bottom: 3rem;
    }

    .case-title {
      font-size: clamp(2.5rem, 6vw, 4rem);
      font-weight: 700;
      line-height: 1.1;
